---
// src/pages/tests/[slug].astro
import Layout from '../../layouts/Layout.astro';
import TestRunner from '../../components/TestRunner.vue';

export async function getStaticPaths() {
    const allTestFiles = import.meta.glob('../../data/*.json', { eager: true });

    return Object.keys(allTestFiles).map((path) => {
        const testData = allTestFiles[path].default;

        const slug = path.split('/').pop().replace('.json', '');

        return {
            params: { slug },
            props: { test: testData },
        };
    });
}

const { test } = Astro.props;
---

<Layout title={test.title}>
    <main class="min-h-screen py-10 px-4">
        <div class="max-w-xl mx-auto mb-6">
            <a href="/tests" class="text-sm text-stone-500 hover:text-blue-600 transition flex items-center gap-2">
                ← Back to all quizzes
            </a>
        </div>

        <TestRunner client:load test={test} />
    </main>
</Layout>