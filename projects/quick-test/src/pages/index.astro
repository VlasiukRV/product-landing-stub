---
import Layout from '../layouts/Layout.astro';

const allTestFiles = import.meta.glob('../data/*.json', { eager: true });

const tests = Object.keys(allTestFiles).map((path) => {
    const testData = allTestFiles[path].default;
    const slug = path.split('/').pop().replace('.json', '');

    return {
        title: testData.title,
        count: testData.questions.length,
        slug: slug,
        // Можно добавить иконку или категорию, если они есть в JSON
        category: testData.category || "General"
    };
});
---

<Layout title="QuizMaster | Level Up Your Skills">
    <main class="bg-[#f8fafc] min-h-screen">

        <section class="bg-white border-b border-slate-200 py-16 px-4">
            <div class="max-w-5xl mx-auto text-center">
        <span class="inline-block px-4 py-1.5 mb-6 text-sm font-bold tracking-wider text-blue-600 uppercase bg-blue-50 rounded-full">
          Interactive Learning
        </span>
                <h1 class="text-4xl md:text-6xl font-extrabold text-slate-900 mb-6 tracking-tight">
                    Master Math & Logic <br/>
                    <span class="text-blue-600">Step by Step.</span>
                </h1>
                <p class="text-lg text-slate-600 max-w-2xl mx-auto mb-10">
                    Challenge yourself with our curated collection of quizzes.
                    Track your progress, identify mistakes, and improve your score.
                </p>

                <div class="flex items-center justify-center gap-4 text-sm font-medium text-slate-500">
                    <span>Join practicing today</span>
                </div>
            </div>
        </section>

        <section class="max-w-5xl mx-auto py-20 px-4">
            <div class="flex items-end justify-between mb-12">
                <div>
                    <h2 class="text-3xl font-bold text-slate-900 mb-2">Quiz Library</h2>
                    <p class="text-slate-500">Pick a topic and start your session</p>
                </div>
                <div class="hidden md:block">
                    <span class="text-sm font-medium text-slate-400">{tests.length} Quizzes Available</span>
                </div>
            </div>

            <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
                {tests.map((test) => (
                        <a
                                href={`/tests/${test.slug}`}
                                class="group relative bg-white border border-slate-200 p-8 rounded-3xl hover:border-blue-500 hover:shadow-2xl hover:shadow-blue-500/10 transition-all duration-300 flex flex-col"
                        >
                            <div class="mb-6 flex justify-between items-start">
                                <div class="p-3 bg-slate-50 text-slate-400 rounded-2xl group-hover:bg-blue-600 group-hover:text-white transition-all duration-300 shadow-sm">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                                    </svg>
                                </div>
                                <span class="bg-slate-100 text-slate-500 text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-tighter">
                {test.count} Questions
              </span>
                            </div>

                            <h3 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-blue-600 transition-colors">
                                {test.title}
                            </h3>
                            <p class="text-slate-500 text-sm mb-8 flex-1">
                                Test your knowledge on {test.title.toLowerCase()}. Perfect for daily practice.
                            </p>

                            <div class="flex items-center text-blue-600 font-bold text-sm uppercase tracking-wider gap-2 group-hover:gap-4 transition-all">
                                Start Quiz
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                                </svg>
                            </div>

                            <div class="absolute top-0 right-0 -mt-2 -mr-2 w-24 h-24 bg-blue-500/5 rounded-full blur-2xl group-hover:bg-blue-500/10 transition-colors"></div>
                        </a>
                ))}
            </div>
        </section>

        <section class="max-w-5xl mx-auto px-4 pb-20">
            <div class="bg-slate-900 rounded-[3rem] p-12 text-center text-white relative overflow-hidden">
                <div class="relative z-10">
                    <h2 class="text-3xl font-bold mb-4">Want to create your own test?</h2>
                    <p class="text-slate-400 mb-8 max-w-md mx-auto">
                        Just add a JSON file to the folder and it will appear here automatically.
                    </p>
                    <div class="flex flex-wrap justify-center gap-4">
                        <code class="bg-white/10 px-4 py-2 rounded-lg text-blue-300 text-sm">src/data/new-test.json</code>
                    </div>
                </div>
                <div class="absolute top-0 left-0 w-64 h-64 bg-blue-600/20 rounded-full blur-[100px] -translate-x-1/2 -translate-y-1/2"></div>
            </div>
        </section>
    </main>
</Layout>