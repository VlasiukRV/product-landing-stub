---
import { ClientRouter } from "astro:transitions";
import '../styles/global.css';

const { title = 'TestFlow', description = 'Simple quiz platform' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@600&display=swap"
            rel="stylesheet"
    />

    <!-- Favicon (optional) -->
    <link rel="icon" href="/favicon.svg" />

    <ClientRouter />

    <!-- Astro styles -->
    <slot name="head" />
</head>

<body class="bg-surface-soft text-text antialiased">

<!-- 🌐 Header -->
<header class="border-b bg-surface">
    <div class="max-w-5xl mx-auto px-4 py-4 flex items-center justify-between">

        <a href="/" class="font-display text-xl font-semibold">
            TestFlow
        </a>

        <nav class="text-sm text-text-muted flex gap-4">
            <a href="/" class="hover:text-primary-600">Home</a>
            <a href="/tests" class="hover:text-primary-600">Tests</a>
        </nav>
    </div>

</header>

<!-- 📦 Main -->
<main class="max-w-5xl mx-auto px-4 py-8 animate-fade-in">
    <slot />
</main>

<!-- 🦶 Footer -->
<footer class="border-t mt-10">
    <div class="max-w-5xl mx-auto px-4 py-6 text-sm text-text-muted text-center">
        © {new Date().getFullYear()} TestFlow — Simple Quiz Engine
    </div>
</footer>

</body>
</html>