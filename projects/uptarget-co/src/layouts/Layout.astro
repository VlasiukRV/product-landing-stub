---
// src/layouts/Layout.astro
interface Props {
    title: string;
}

const { title } = Astro.props;
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
</head>
<body class="body bg-white text-[#1a1a1c] font-sans">
<slot name="header" />

<main>
    <slot />
</main>

<slot name="footer" />
</body>
</html>