---
// src/pages/team.astro

import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import TeamSection from "../components/TeamSection.astro";
import RecruitSection from "../components/RecruitSection.astro";
import TeamHeroSection from "../components/TeamHeroSection.astro";
import ContactModal from "../components/ContactModal.vue";
---

<Layout title="Uptarget - Dedicated Team">

    <Navbar slot="header" />

    <TeamSection />

    <RecruitSection />

    <TeamHeroSection />

    <Footer slot="footer" />

    <ContactModal
            slot="modal_form"
            client:only="vue"
            formName="contact_form"
    />

</Layout>