---
// src/pages/careers.astro

import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CareersHeroSection from "../components/CareersHeroSection.astro";
import VacanciesSection from "../components/VacanciesSection.astro";
import PerksSection from "../components/PerksSection.astro";
import CultureSection from "../components/CultureSection.astro";
import TeamTestimonialsSection from "../components/TeamTestimonialsSection.astro";


---

<Layout title="Uptarget - Dedicated Team">

    <Navbar slot="header"/>

    <CareersHeroSection />

    <div class="relative z-[45] -mt-20 md:-mt-40 xl:-mt-60">
        <VacanciesSection />
    </div>

    <PerksSection />

    <CultureSection />

    <TeamTestimonialsSection />

    <Footer slot="footer" />

</Layout>