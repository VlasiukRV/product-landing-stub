---
import peopleItems from '../data/people.json';
---

<section class="people py-0 px-4 max-w-[1440px] mx-auto">
    <h2 class="text-[32px] md:text-[56px] font-bold text-center mb-16">Our People</h2>

    <div class="flex flex-col gap-0">
        {peopleItems.map((person, index) => {
            const isReverse = index % 2 !== 0;
            return (
                <div class={`flex flex-col md:flex-row ${isReverse ? 'md:flex-row-reverse' : ''} ${isReverse ? 'bg-[#f4f4f4]' : ''} overflow-hidden`}>

                    <div class="w-full md:w-1/2 p-8 md:p-16 flex flex-col justify-center">
                        <img src="/img/Quotes-1.svg"
                             alt="Quotes" class="w-10 mb-8" />

                        <p class="text-[16px] md:text-[20px] lg:text-[24px] leading-relaxed mb-6 italic">
                            "{person.quote}"
                        </p>

                        <div class="font-bold text-[20px]">{person.name}</div>
                        <div class="text-gray-500">{person.position}</div>
                    </div>

                    <div class="w-full md:w-1/2 p-4 md:p-8">
                        <img src={person.image}
                             alt={person.name}
                             class="w-full h-[300px] md:h-[400px] object-contain" />
                    </div>
                </div>
            );
        })}
    </div>
</section>