---
// src/components/TeamHeroSection.astro

---

<section class="team-section pt-16 bg-white">
    <div class="max-w-7xl mx-auto px-6 text-center">

        <div class="mx-auto mb-8 w-[80px] h-auto text-black transition-transform duration-300 hover:scale-125 cursor-pointer">
            <svg viewBox="0 0 100 89" xmlns="http://www.w3.org/2000/svg" class="w-full h-full fill-current">
                <g transform="translate(-10, -15)">
                    <polygon points="66.7015807 15.838607 53.2993803 15.838607 10.87687 92.0921425 19.5389999 103.161172 54.2254683 94.0167492 54.2254683 78.2365211 32.9842535 83.8362206 60.0005914 35.2753668 87.0160417 83.8362206 65.7746049 78.2363002 65.7746049 94.0165282 100.461295 103.161172 109.123203 92.0921425"></polygon>
                </g>
            </svg>
        </div>

        <div class="footprint-text max-w-3xl mx-auto text-xl md:text-2xl font-medium text-[#1a1a1c] mb-12">
            Behind the scenes, our 30+ developers, QA engineers, and DevOps specialists work remotely across Eastern Europe, helping startups scale faster and smarter.
        </div>
    </div>

    <div class="w-full">
        <img src="https://cdn.prod.website-files.com/65a13d5213646f4a614e2266/68801b7ff43c21b4a6907e02_team.webp"
             alt="Team at work"
             class="team-fullscreen w-full h-auto object-cover" />
    </div>
</section>