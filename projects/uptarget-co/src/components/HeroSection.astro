---
// src/components/HeroSection.astro

const title = `Your<br>Dedicated<br>Team`
const content = `We are a technology consultancy and software <br>
                development company that provides top-notch <br>
                engineers, helping your product to grow.`

---
<section class="hero-container relative w-full min-h-screen lg:min-h-[800px] xl:h-[900px] overflow-hidden bg-white xl:block flex flex-col">

    <div class="hero-graphics relative xl:absolute inset-0 z-10 w-full h-[50vh] md:h-[60vh] xl:h-full">
        <div class="team relative xl:absolute top-0 left-0 w-full
                    xl:w-[50vw] h-full xl:h-[750px]
                    flex justify-center xl:justify-end items-center xl:items-end

                    pb-10 xl:pb-[30px]
                    xl:pr-[105px] 2xl:pr-[200px]
                    z-[6] overflow-hidden">
            <img src="/img/Cover-Hero.webp" alt="Hero Cover" class="absolute inset-0 w-full h-full object-cover z-0" />

            <a href="/team" class="button-l-outline relative border-2 border-white text-white px-6 py-4 xl:px-8 xl:py-6 rounded-full uppercase font-bold hover:bg-white hover:text-black transition-all z-10">
                meet the team
            </a>
        </div>

        <div class="hidden xl:block absolute inset-0 mx-auto max-w-7xl pointer-events-none">
            <img src="/img/Rays-M.svg" alt="" class="absolute top-[20%] left-[50%] -translate-x-1/2 w-[30%] z-[3] opacity-50" />
            <img src="/img/Rays-L.svg" alt="" class="absolute top-[45%] left-[45%] -translate-x-1/2 w-[50%] z-[2] opacity-50" />
        </div>
    </div>

    <div class="hero-msg relative z-30 w-full
                md:absolute
                md:left-[10%] md:bottom-[10%]
                lg:left-[45%] lg:bottom-[0%]
                xl:left-[45%] xl:bottom-[0%]
                2xl:left-[45%] 2xl:bottom-[0%]

                px-6 xl:px-0 mt-[-60px] lg:mt-0 group">

        <div class="absolute -inset-2 bg-gradient-to-r from-[#fd0] to-orange-400 blur-2xl opacity-20 transition duration-700"></div>

        <div class="hero-msg-box relative pointer-events-auto
                    p-8 md:p-12
                    xl:pt-[80px] xl:pl-[80px] xl:pr-[40px] xl:pb-[80px]
                    bg-white z-[2] xl:rounded-none shadow-xl xl:shadow-none">

            <h1 class="hero-title text-[40px] md:text-[54px] xl:text-[80px] 2xl:text-[90px] font-bold leading-[1.1] text-[#1a1a1c] mb-6" set:html={title}>
            </h1>

            <p class="hero-text text-base md:text-lg xl:text-lg text-[#1a1a1c]/80 leading-relaxed max-w-xl" set:html={content}>
            </p>
        </div>
    </div>

</section>