---
import PageLayout from "../../layouts/PageLayout.astro";
import GroupSelector from "../../components/schedule/GroupSelector.vue";
import groups from "../../data/groups.json";
---

<PageLayout
        title="Розклад занять"
        breadcrumbs={[{ label: "Розклад" }]}
>
    <section class="max-w-6xl mx-auto px-6 py-12 md:py-24">
        <div class="relative mb-24 text-center">
            <div class="absolute inset-x-0 -top-20 -z-10 flex justify-center opacity-30 blur-[120px]">
                <div class="h-[200px] w-[400px] bg-gradient-to-r from-blue-600 to-indigo-600 rounded-full"></div>
            </div>

            <div class="inline-flex items-center gap-2 px-4 py-2 bg-blue-50 text-blue-600 rounded-full text-[10px] font-black uppercase tracking-[0.2em] mb-6 border border-blue-100/50">
                <span class="relative flex h-2 w-2">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-600"></span>
                </span>
                Система розкладу 2026
            </div>

            <h1 class="text-5xl md:text-7xl font-black text-slate-900 tracking-tighter mb-8 italic">
                Оберіть свою <span class="text-blue-600">групу</span>
            </h1>
            <p class="text-lg text-slate-400 max-w-2xl mx-auto font-medium leading-relaxed">
                Доступ до актуального графіку занять, аудиторій та викладачів у реальному часі.
            </p>
        </div>

        <div class="relative">
            <GroupSelector client:load groups={groups} />
        </div>

        <div class="mt-32 grid grid-cols-1 md:grid-cols-3 gap-6">
            {[
                { label: "Чисельник", sub: "Тиждень A", icon: "A", color: "blue" },
                { label: "Знаменник", sub: "Тиждень B", icon: "B", color: "indigo" },
                { label: "Синхронізація", sub: "Оновлено сьогодні", icon: "✓", color: "emerald" }
            ].map(item => (
                    <div class="flex items-center gap-5 p-6 bg-white border border-slate-100 rounded-[2rem] shadow-sm italic font-bold">
                        <div class={`w-12 h-12 rounded-2xl bg-${item.color}-50 flex items-center justify-center text-${item.color}-600 text-lg shadow-inner`}>
                            {item.icon}
                        </div>
                        <div>
                            <p class="text-sm text-slate-800 uppercase tracking-tighter">{item.label}</p>
                            <p class="text-[10px] text-slate-400 uppercase tracking-widest">{item.sub}</p>
                        </div>
                    </div>
            ))}
        </div>
    </section>
</PageLayout>