---
// pages/schedule/[group].astro
import PageLayout from "../../layouts/PageLayout.astro";
import ScheduleTabs from "../../components/blocks/ScheduleTabs.astro";
import groups from "../../data/groups.json";

export async function getStaticPaths() {
    return groups.map((g) => ({ params: { group: g.id } }));
}

const { group } = Astro.params;
const scheduleModule = await import(`../../data/schedule/${group}.json`);
const data = scheduleModule.default;

const days = [
    { label: "Понеділок", key: "monday" },
    { label: "Вівторок", key: "tuesday" },
    { label: "Середа", key: "wednesday" },
    { label: "Четвер", key: "thursday" },
    { label: "П'ятниця", key: "friday" }
];
---

<PageLayout
        title={`Група ${data.name}`}
        breadcrumbs={[{ label: "Розклад", href: "/schedule" }, { label: data.name }]}
>
    <section class="max-w-6xl mx-auto px-6 py-12">

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-16">
            <div class="lg:col-span-2 bg-slate-900 rounded-[3rem] p-10 text-white relative overflow-hidden flex flex-col justify-between min-h-[280px]">
                <div class="absolute top-0 right-0 w-64 h-64 bg-blue-500/20 rounded-full blur-[80px]"></div>

                <div class="relative z-10">
                    <div class="flex items-center gap-3 mb-6">
                        <span class="px-4 py-1.5 bg-blue-600 rounded-full text-[10px] font-bold uppercase tracking-widest">Група {data.name}</span>
                        <span class="text-blue-300 text-[10px] font-black uppercase tracking-widest">Курс {data.year}</span>
                    </div>
                    <h1 class="text-4xl md:text-5xl font-black uppercase italic leading-none tracking-tighter">
                        {data.specialty}
                    </h1>
                </div>

                <div class="relative z-10 mt-8 flex items-center gap-6 border-t border-white/10 pt-8">
                    <div class="flex flex-col">
                        <span class="text-[9px] uppercase font-black text-slate-500 tracking-widest">Тиждень</span>
                        <span class="text-xl font-black italic uppercase text-blue-400">{data.weekType === 'A' ? 'Чисельник' : 'Знаменник'}</span>
                    </div>
                </div>
            </div>

            <div class="bg-blue-50 border border-blue-100 rounded-[3rem] p-10 flex flex-col justify-between">
                <div>
                    <div class="w-12 h-12 bg-blue-600 rounded-2xl flex items-center justify-center text-2xl mb-6 shadow-lg shadow-blue-200">📅</div>
                    <h3 class="text-lg font-black text-blue-900 uppercase italic leading-tight mb-2">Статус розкладу</h3>
                    <p class="text-blue-700/70 text-sm font-bold italic leading-relaxed">Дані синхронізовані з навчальною частиною та актуальні на сьогодні.</p>
                </div>
                <div class="mt-8 flex items-center gap-2">
                    <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
                    <span class="text-[10px] font-black uppercase tracking-widest text-emerald-600">Оновлено щойно</span>
                </div>
            </div>
        </div>

        <div class="relative">
            <ScheduleTabs days={days} schedule={data.schedule} />
        </div>

        <div class="mt-20 p-8 bg-slate-50 rounded-[2.5rem] border border-slate-100 flex flex-col md:flex-row items-center gap-6">
            <div class="text-4xl">💡</div>
            <div class="text-xs md:text-sm font-bold text-slate-500 italic text-center md:text-left leading-relaxed">
                Якщо ви помітили неточність у розкладі або зміну аудиторії, яка не відображена тут, будь ласка, повідомте старосту групи або зверніться до навчальної частини.
            </div>
        </div>

    </section>
</PageLayout>