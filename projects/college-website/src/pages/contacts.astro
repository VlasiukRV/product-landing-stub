---
import PageLayout from "../layouts/PageLayout.astro";

const contactInfo = [
    {
        icon: "📍",
        title: "Адреса",
        content: "вул. Центральна, 12, м. Артур, Іллінойс",
        link: "https://maps.google.com/?q=Central+st+12+Arthur+Illinois",
        type: "address"
    },
    {
        icon: "📞",
        title: "Приймальня директора",
        content: "+38-05259-2-24-80",
        link: "tel:+38-05259-2-24-80",
        type: "phone"
    },
    {
        icon: "💳",
        title: "Бухгалтерія",
        content: "+38-05259-2-23-74",
        link: "tel:+38-05259-2-23-74",
        type: "phone"
    },
    {
        icon: "🏠",
        title: "Гуртожиток",
        content: "+38-05259-2-13-84",
        link: "tel:+38-05259-2-13-84",
        type: "phone"
    },
    {
        icon: "✉️",
        title: "Email",
        content: "ulynovkaptu11@ukr.net",
        link: "mailto:ulynovkaptu11@ukr.net",
        type: "email"
    },
    {
        icon: "🌐",
        title: "Facebook",
        content: "Сторінка закладу",
        link: "https://www.facebook.com/profile.php?id=100064594586301",
        type: "social"
    },
    {
        icon: "⏰",
        title: "Графік роботи",
        content: "Пн-Пт: 08:00 – 17:00",
        subContent: "Сб-Нд: Вихідний",
        type: "time"
    }
];
---

<PageLayout
        breadcrumbs={[{ label: "Контакти" }]}
>
    <section class="max-w-7xl mx-auto px-6 py-16">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">

            <div class="lg:col-span-7 space-y-16">

                <div>
                    <h1 class="text-5xl font-black text-slate-900 tracking-tight mb-6">
                        Залишаймося <span class="text-blue-600">на зв'язку</span>
                    </h1>
                    <p class="text-lg text-slate-500 max-w-xl leading-relaxed">
                        Маєте запитання щодо вступу, навчання або співпраці? Наша команда готова допомогти вам у робочі години.
                    </p>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    {contactInfo.map((info) => (
                            <div class="group p-5 rounded-2xl border border-slate-100 bg-white hover:border-blue-200 hover:shadow-xl hover:shadow-blue-500/5 transition-all duration-300">
                                <div class="flex items-start gap-4">
                                    <div class="w-12 h-12 rounded-xl bg-slate-50 flex items-center justify-center text-2xl group-hover:scale-110 group-hover:bg-blue-50 transition-all duration-300">
                                        {info.icon}
                                    </div>
                                    <div class="flex-1 min-w-0">
                                        <h3 class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-1">{info.title}</h3>
                                        {info.link ? (
                                                <a href={info.link} class="text-slate-700 font-semibold hover:text-blue-600 transition block truncate">
                                                    {info.content}
                                                </a>
                                        ) : (
                                                <p class="text-slate-700 font-semibold">{info.content}</p>
                                        )}
                                        {info.subContent && <p class="text-xs text-slate-400 mt-1">{info.subContent}</p>}
                                    </div>
                                </div>
                            </div>
                    ))}
                </div>

                <div class="relative overflow-hidden rounded-3xl bg-slate-900 p-8 md:p-10 shadow-2xl">
                    <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/2 w-64 h-64 bg-blue-600/20 rounded-full blur-3xl"></div>

                    <div class="relative z-10">
                        <h3 class="text-2xl font-bold text-white mb-2">Надіслати повідомлення</h3>
                        <p class="text-slate-400 text-sm mb-8">Ми зазвичай відповідаємо протягом одного робочого дня.</p>

                        <form class="space-y-5" onsubmit="return false;">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                                <div class="space-y-2">
                                    <label class="text-xs font-bold uppercase tracking-wider text-slate-400 ml-1">Ваше ім'я</label>
                                    <input type="text" class="w-full bg-slate-800/50 border border-slate-700 rounded-xl px-4 py-3 text-white placeholder:text-slate-500 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition" placeholder="Олександр" />
                                </div>
                                <div class="space-y-2">
                                    <label class="text-xs font-bold uppercase tracking-wider text-slate-400 ml-1">Електронна пошта</label>
                                    <input type="email" class="w-full bg-slate-800/50 border border-slate-700 rounded-xl px-4 py-3 text-white placeholder:text-slate-500 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition" placeholder="name@example.com" />
                                </div>
                            </div>
                            <div class="space-y-2">
                                <label class="text-xs font-bold uppercase tracking-wider text-slate-400 ml-1">Повідомлення</label>
                                <textarea rows="4" class="w-full bg-slate-800/50 border border-slate-700 rounded-xl px-4 py-3 text-white placeholder:text-slate-500 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition" placeholder="Опишіть ваше питання..."></textarea>
                            </div>
                            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-4 rounded-xl shadow-lg shadow-blue-600/20 transition-all active:scale-[0.98]">
                                Відправити запит
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="lg:col-span-5">
                <div class="sticky top-24 h-[600px] rounded-3xl overflow-hidden border border-slate-100 shadow-2xl bg-white p-2">
                    <div class="w-full h-full rounded-[20px] overflow-hidden grayscale-[0.2] hover:grayscale-0 transition-all duration-700">
                        <iframe
                                src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d12074.604704202091!2d30.2311993!3d48.3308339!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x40cde2020d29c9b3%3A0x3f52ffb9c5b0d837!2z0JHQu9Cw0LPQvtCy0ZbRidC10L3RgdGM0LrQuNC5INGA0LDQudC-0L3QvdC40Lkg0YbQtdC90YLRgCDQv9C10YDQstC40L3QvdC-0Zcg0LzQtdC00LjQutC-LdGB0LDQvdGW0YLQsNGA0L3QvtGXINC00L7Qv9C-0LzQvtCz0Lg!5e1!3m2!1suk!2sus!4v1776293744798!5m2!1suk!2sus"
                                width="100%"
                                height="100%"
                                style="border:0;"
                                allowfullscreen=""
                                loading="lazy"
                                referrerpolicy="no-referrer-when-downgrade">
                        </iframe>
                    </div>
                </div>
            </div>
        </div>
    </section>
</PageLayout>