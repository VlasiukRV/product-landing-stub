---
// pages/index.astro

import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/blocks/Hero.astro";
import QuickLinks from "../components/blocks/QuickLinks.astro";
import NewsList from "../components/blocks/NewsList.astro";
import NewsFeed from "../components/blocks/NewsFeed.vue";

import news from "../data/news.json";
import fbNews from "../data/fb-news.json";

import GridLinks from "../components/blocks/GridLinks.astro";

const links = [
    { title: "Абітурієнту", href: "/admission" },
    { title: "Викладачі", href: "/staff" },
    { title: "Розклад", href: "/schedule" },
    { title: "Контакти", href: "/contacts" }
];
---

<BaseLayout>
    <Hero
            title="Ліцей сучасної освіти"
            subtitle="Професійна освіта та розвиток кар'єри"
    />

    <div class="max-w-6xl mx-auto px-4 py-10 space-y-10">
        <section class="py-12">
            <div class="col-span-full">
                <h2 class="text-3xl font-bold text-slate-800 mb-2">Швидкий доступ</h2>
                <div class="w-20 h-1.5 bg-blue-600 rounded-full mb-8"></div>
            </div>
            <QuickLinks links={links} />
        </section>

        <section class="py-12">
            <div class="mb-12">
                <h2 class="text-3xl font-black text-slate-900 uppercase italic">Медіа-центр</h2>
                <div class="w-20 h-1.5 bg-blue-600 rounded-full mt-2"></div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

                <div class="lg:col-span-2">
                    <div class="flex items-center justify-between mb-8">
                        <h3 class="text-xs font-black uppercase tracking-[0.2em] text-slate-400 flex items-center gap-3">
                            <span class="w-2 h-2 rounded-full bg-blue-600"></span>
                            Новини технікуму
                        </h3>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <NewsList news={news.slice(0, 4)} />
                    </div>
                </div>

                <div class="lg:col-span-1">
                    <div class="sticky top-24">
                        <h3 class="text-xs font-black uppercase tracking-[0.2em] text-blue-600 mb-8">
                            Прямий ефір Facebook
                        </h3>

                        <div class="bg-slate-50 rounded-[2.5rem] p-6 border border-slate-100 shadow-sm">
                            <NewsFeed
                                    client:load
                                    initialData={fbNews.slice(0, 3)}
                                    isSidebar={true}
                            />

                            <a href="https://www.facebook.com/profile.php?id=100064594586301" class="mt-8 block text-center py-4 bg-white border border-blue-100 text-blue-600 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-blue-600 hover:text-white transition-all shadow-sm">
                                Всі пости у Facebook
                            </a>
                        </div>
                    </div>
                </div>

            </div>
        </section>

        <section class="py-12">
            <GridLinks
                    title="Корисні посилання"
                    columns={3}
                    items={[
                        {
                            title: "Сторінка дирекктора",
                            href: "/director",
                            description: "Керівництво та управління",
                            icon: "👨‍🏫"
                        },
                        {
                            title: "Методичний кабінет",
                            href: "/methodical-cabinet",
                            description: "Скоро буде доступно",
                            icon: "📚"
                        }
                    ]}
            />
        </section>
    </div>
</BaseLayout>