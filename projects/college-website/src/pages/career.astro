    { name: "Мокружицька І.В.", role: "Викладач, кар'єрний консультант", img: "http://bpl.kr.ua/images/pedpracivnuku/maistru/%D0%A7%D0%B5%D1%80%D0%BD%D0%BE%D0%B2%D0%BE%D0%B4%D1%81%D1%8C%D0%BA%D0%B0_%D0%90._%D0%94.1.jpg" },
    { name: "Тарасенко Т.С.", role: "Юрист", img: "/images/news/2024/1_VERESNJA/Центр_карєри/96.jpg" },
    { name: "Драганець С.О.", role: "Секретар Центру кар'єри", img: "http://bpl.kr.ua/images/news/2023/1_veresnja/ONOVLENI_FOTO/Ped.pracivnuku/2.jpg" },
    { name: "Барановська О.О.", role: "Викладач, кар'єрний консультант", img: "http://bpl.kr.ua/images/pedpracivnuku/vukladachi/%D0%91%D0%B0%D1%80%D0%B0%D0%BD%D0%BE%D0%B2%D1%81%D1%8C%D0%BA%D0%B0_%D0%9E.%D0%9E.1.JPG" },
