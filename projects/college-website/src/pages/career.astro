    { name: "Міхальчук В.М.", role: "Заступник директора з НВР, заступник керівника", img: "http://bpl.kr.ua/images/pedpracivnuku/admin/%D0%9C%D1%96%D1%85%D0%B0%D0%BB%D1%8C%D1%87%D1%83%D0%BA_%D0%92.%D0%9C.1.JPG" },
