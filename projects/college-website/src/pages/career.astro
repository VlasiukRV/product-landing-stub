    { name: "Мотиваційний лист: як правильно написати", url: "https://docs.google.com/forms/d/e/1FAIpQLSdMS3_QzhlW6P5QBeqDkjgehaxJpEprfmkCrnrzjbNOlZGV-Q/viewform", type: "link" },
    { name: "Мотиваційний лист (вправи).", url: "https://drive.google.com/file/d/1xNyaaKiOODexEZX2Mb0n0JddF81PaIg9/view", type: "link" },
    { name: "Інструкція щодо мотиваційного листа.", url: "https://drive.google.com/file/d/1iuKnSn8slIwYPyvGZ_yulTYrXRrnHlfW/view", type: "link" },
    { name: "Документи претендента на вакансію", url: "https://drive.google.com/file/d/1yo1z2K_V1v5sN2fkcncyvM5CZfd-qfy6/view", type: "link" },
    { name: "Основні правила складання резюме", url: "https://drive.google.com/file/d/1GURCERWvkTjWyKFTHQ_B_9ptyLBW5wmB/view", type: "link" }
