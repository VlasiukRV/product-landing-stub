const partners = [
    { name: "СФГ «КОНДОР»", href: "https://drive.google.com/file/d/1ECRlLBh03zxrijLmbYPFav34wMuuqoSM/view" },
    { name: "СТОВ «НИВА»", href: "https://drive.google.com/file/d/1ECRlLBh03zxrijLmbYPFav34wMuuqoSM/view" },
