    { name: "Тест: Яка професія підходить саме тобі", url: "https://docs.google.com/forms/d/e/1FAIpQLSdMS3_QzhlW6P5QBeqDkjgehaxJpEprfmkCrnrzjbNOlZGV-Q/viewform", type: "link" },
