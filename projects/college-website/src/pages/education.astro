---
import PageLayout from "../layouts/PageLayout.astro";
import FileList from "../components/ui/FileList.astro";

const pillars = [
    {
        title: "Студентське самоврядування",
        desc: "Твій голос має значення. Рада студентів організовує заходи, захищає твої права та впроваджує круті ініціативи.",
        icon: "📢",
        color: "bg-purple-50 text-purple-600"
    },
    {
        title: "Дозвілля та творчість",
        desc: "Гуртки, вокальні студії, танцювальні колективи та щорічні фестивалі талантів.",
        icon: "🎸",
        color: "bg-pink-50 text-pink-600"
    },
    {
        title: "Спорт та здоров’я",
        desc: "Спортивні секції, змагання між групами та популяризація здорового способу життя.",
        icon: "🏆",
        color: "bg-amber-50 text-amber-600"
    },
    {
        title: "Волонтерство",
        desc: "Допомога тим, хто цього потребує, благодійні акції та еко-ініціативи нашого закладу.",
        icon: "🤝",
        color: "bg-emerald-50 text-emerald-600"
    }
];

const documents = [
    { name: "План виховної роботи на 2025-2026 н.р.", url: "/docs/vikhovna-plan.pdf", size: "2.1 MB" },
    { name: "Положення про студентське самоврядування", url: "/docs/samovryaduvannya.pdf", size: "1.4 MB" },
    { name: "Кодекс академічної доброчесності та етики", url: "/docs/ethics.docx", size: "850 KB" }
];
---

<PageLayout
        title="Виховна робота"
        breadcrumbs={[{ label: "Студенту", href: "/students" }, { label: "Виховна робота" }]}
>
    <section class="max-w-7xl mx-auto px-6 py-12 md:py-20">
        <div class="relative bg-slate-900 rounded-[3rem] p-8 md:p-16 overflow-hidden text-center md:text-left">
            <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-blue-600/20 to-transparent"></div>

            <div class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                <div>
                    <span class="inline-block px-4 py-1.5 bg-blue-500/20 text-blue-400 rounded-full text-[10px] font-black uppercase tracking-[0.2em] mb-6">
                        Життя за межами аудиторій
                    </span>
                    <h1 class="text-4xl md:text-6xl font-black text-white mb-6 leading-tight">
                        Твій розвиток — <br/><span class="text-blue-500">наш пріоритет</span>
                    </h1>
                    <p class="text-slate-400 text-lg leading-relaxed mb-8">
                        Студентські роки — це час для самовираження. Ми створюємо умови, щоб кожен знайшов себе у творчості, спорті чи лідерстві.
                    </p>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div class="p-6 bg-white/5 backdrop-blur-md border border-white/10 rounded-3xl text-center">
                        <div class="text-3xl mb-2">🎨</div>
                        <div class="text-white font-bold text-sm uppercase">Творчість</div>
                    </div>
                    <div class="p-6 bg-white/5 backdrop-blur-md border border-white/10 rounded-3xl text-center translate-y-6">
                        <div class="text-3xl mb-2">⚽</div>
                        <div class="text-white font-bold text-sm uppercase">Спорт</div>
                    </div>
                    <div class="p-6 bg-white/5 backdrop-blur-md border border-white/10 rounded-3xl text-center">
                        <div class="text-3xl mb-2">🌟</div>
                        <div class="text-white font-bold text-sm uppercase">Лідерство</div>
                    </div>
                    <div class="p-6 bg-white/5 backdrop-blur-md border border-white/10 rounded-3xl text-center translate-y-6">
                        <div class="text-3xl mb-2">📡</div>
                        <div class="text-white font-bold text-sm uppercase">Медіа</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 py-12">
        <div class="text-center mb-16">
            <h2 class="text-3xl md:text-4xl font-black text-slate-900 mb-4 tracking-tight">Напрямки виховної діяльності</h2>
            <div class="h-1.5 w-20 bg-blue-600 mx-auto rounded-full"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            {pillars.map(p => (
                    <div class="flex flex-col p-8 bg-white border border-slate-100 rounded-[2.5rem] shadow-sm hover:shadow-xl transition-all duration-300">
                        <div class={`w-14 h-14 rounded-2xl ${p.color} flex items-center justify-center text-2xl mb-6`}>
                            {p.icon}
                        </div>
                        <h3 class="font-black text-slate-900 mb-4 leading-snug">{p.title}</h3>
                        <p class="text-slate-500 text-sm leading-relaxed">{p.desc}</p>
                    </div>
            ))}
        </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 py-12">
        <div class="relative bg-gradient-to-br from-blue-700 via-indigo-700 to-slate-900 rounded-[2.5rem] p-8 md:p-14 text-white overflow-hidden shadow-[0_20px_50px_rgba(37,99,235,0.3)] ring-1 ring-white/20">

            <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/4 w-96 h-96 bg-blue-400/20 rounded-full blur-[80px]"></div>
            <div class="absolute bottom-0 left-0 translate-y-1/2 -translate-x-1/4 w-64 h-64 bg-indigo-500/20 rounded-full blur-[60px]"></div>

            <div class="relative z-10 flex flex-col md:flex-row items-center gap-10">


                <div class="flex-1 text-center md:text-left">
                    <div class="inline-flex items-center gap-2 px-3 py-1 bg-emerald-500/20 text-emerald-300 rounded-full text-[10px] font-black uppercase tracking-widest mb-4 border border-emerald-500/30">
                        <span class="w-1.5 h-1.5 bg-emerald-400 rounded-full animate-pulse"></span>
                        Ми поруч
                    </div>
                    <h2 class="text-3xl md:text-4xl font-black mb-4 tracking-tight">Психологічна підтримка</h2>
                    <p class="text-blue-100/80 text-lg leading-relaxed max-w-2xl">
                        Стрес перед іспитами? Труднощі в спілкуванні? Наш психолог допоможе знайти внутрішній баланс. Це повністю <span class="text-white font-bold underline decoration-blue-400 underline-offset-4">безкоштовно та конфіденційно</span>.
                    </p>
                </div>

                <div class="flex-shrink-0">
                    <a href="/contacts" class="inline-flex items-center gap-3 px-10 py-5 bg-white text-blue-700 rounded-2xl font-black uppercase text-xs tracking-[0.15em] hover:bg-blue-50 hover:scale-105 hover:shadow-lg transition-all duration-300 whitespace-nowrap group">
                        Записатися
                        <span class="text-lg group-hover:translate-x-1 transition-transform">→</span>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <section class="max-w-4xl mx-auto px-6 py-20">
        <div class="bg-slate-50 border border-slate-100 rounded-[3rem] p-8 md:p-12">
            <FileList title="Нормативна база та плани" files={documents} />
        </div>
    </section>
</PageLayout>