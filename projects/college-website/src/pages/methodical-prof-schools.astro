---
import PageLayout from "../layouts/PageLayout.astro";

const headsSchool = {
    title: "Школа голів МК",
    desc: "Координація методичної роботи та стратегічне планування",
    icon: "🎓",
    docs: [
        { name: "Положення про Школу голів МК", type: "pdf" },
        { name: "План засідань 2023-2024 н.р.", type: "doc" },
        { name: "План засідань 2022-2023 н.р.", type: "doc" },
        { name: "План засідань 2021-2022 н.р.", type: "doc" },
    ]
};

const youngTeacher = {
    title: "Школа молодого педагога",
    desc: "Підтримка та адаптація педагогів-початківців",
    icon: "🌱",
    sections: [
        {
            group: "Нормативна база",
            links: ["Положення про Школу педагога-початківця", "Положення про наставництво", "Склад школи"]
        },
        {
            group: "Методична допомога",
            links: ["Поради наставника", "Індивідуальний план наставника", "Анкети"]
        },
        {
            group: "Планування",
            links: ["План засідань (1-й рік)", "План засідань (3-й рік)"]
        }
    ]
};

const masterSchool = {
    title: "Школа майстра в/н",
    desc: "Професійний розвиток майстрів виробничого навчання",
    icon: "🛠️",
    materials: [
        "Сучасні педагогічні технології: цікаво та ефективно",
        "Від традиційного до інноваційного конструювання уроку",
        "Методика розробки дидактичних засобів",
        "Типи і види уроків виробничого навчання",
        "Навчально-методична документація майстра ЗП(ПТ)О",
        "Сучасні підходи до підготовки уроку",
        "Інструментарій сучасного уроку в/н"
    ],
    samples: ["Зразки інформаційних плакатів", "Зразки технологічних карток (9 зразків)", "Зразки карток нагадування"]
};

const ppdCatalog = [
    {
        author: "Безносюк В.І.",
        role: "Викладач інформатики та технології",
        topic: "Використання інтерактивної онлайн-дошки Miro та платформи Book Creator — як засіб активізації діяльнісного підходу у навчанні",
        tags: ["Miro", "Book Creator", "Цифровізація"]
    },
    {
        author: "Середенко О.В.",
        role: "Викладач проф-теорет підготовки",
        topic: "Google застосунки та учнівські проєкти як дієвий спосіб формування професійних компетенцій будівельників",
        tags: ["Google Workspace", "Будівництво", "Проєкти"]
    },
    {
        author: "Черноводський С.М.",
        role: "Майстер виробничого навчання",
        topic: "Барельєфна штукатурка на уроках професійно-практичної підготовки",
        tags: ["Майстерність", "Штукатурка", "Декор"]
    },
    {
        author: "Собчук К.І.",
        role: "Викладач хімії, біології і екології",
        topic: "Використання онлайн-дошки Padlet для індивідуальних завдань та проєктної роботи",
        tags: ["Padlet", "Природничі науки"]
    },
    {
        author: "Черноводська А.Д.",
        role: "Майстер виробничого навчання",
        topic: "Впровадження елементів молекулярної кулінарії на уроках виробничого навчання",
        tags: ["Кулінарія", "Інновації"]
    },
    {
        author: "Ханаєва Я.М.",
        role: "Викладач фізики і астрономії",
        topic: "Використання сервісу Canva для мотивації навчальної діяльності учнів",
        tags: ["Canva", "Мотивація", "Фізика"]
    },
    {
        author: "Ровінська Л.А.",
        role: "Викладач проф-теорет підготовки",
        topic: "Збірник технологічних задач професійного спрямування для професії 'Кухар'",
        tags: ["Задачі", "Кухар", "Методика"]
    }
];

---

<PageLayout title="Школи професійної майстерності" breadcrumbs={[{label: "Методична робота", href: "/methodical-work"}, {label: "Школи майстерності"}]}>

    <section class="max-w-7xl mx-auto px-6 py-16">
        <h1 class="text-4xl md:text-6xl font-black text-slate-900 uppercase italic mb-16 tracking-tight">
            Система <span class="text-blue-600">наставництва</span> <br/> та зростання
        </h1>

        <div class="grid grid-cols-1 gap-12">

            <div id="heads-school" class="bg-white rounded-[3rem] border border-slate-100 shadow-sm overflow-hidden flex flex-col md:flex-row">
                <div class="md:w-1/3 bg-slate-900 p-12 text-white flex flex-col justify-between">
                    <div>
                        <span class="text-5xl mb-6 block">{headsSchool.icon}</span>
                        <h2 class="text-3xl font-black uppercase italic leading-tight mb-4">{headsSchool.title}</h2>
                        <p class="text-slate-400 text-sm">{headsSchool.desc}</p>
                    </div>
                    <div class="mt-8 pt-8 border-t border-white/10">
                        <span class="text-[10px] uppercase font-bold tracking-[0.2em] text-blue-400">Статус: Діюча</span>
                    </div>
                </div>
                <div class="md:w-2/3 p-8 md:p-12">
                    <h3 class="font-black text-slate-900 uppercase italic mb-6">Документація та плани:</h3>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        {headsSchool.docs.map(doc => (
                                <a href="#" class="flex items-center gap-4 p-4 rounded-2xl bg-slate-50 border border-slate-100 hover:border-blue-300 hover:bg-white transition-all group">
                                    <div class="w-10 h-10 rounded-lg bg-white flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform text-xl">📄</div>
                                    <span class="text-xs font-bold text-slate-700 leading-snug">{doc.name}</span>
                                </a>
                        ))}
                    </div>
                </div>
            </div>

            <div id="young-teacher" class="bg-white rounded-[3rem] border border-slate-100 shadow-sm overflow-hidden">
                <div class="p-8 md:p-12 border-b border-slate-50 bg-blue-50/30 flex flex-col md:flex-row justify-between items-center gap-6">
                    <div class="flex items-center gap-6 text-center md:text-left">
                        <span class="text-5xl">{youngTeacher.icon}</span>
                        <div>
                            <h2 class="text-3xl font-black uppercase italic text-slate-900">{youngTeacher.title}</h2>
                            <p class="text-slate-500 text-sm font-medium">{youngTeacher.desc}</p>
                        </div>
                    </div>
                    <a href="#" class="px-8 py-4 bg-slate-900 text-white rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-blue-600 transition-colors">Завантажити пакет документів</a>
                </div>
                <div class="p-8 md:p-12 grid grid-cols-1 md:grid-cols-3 gap-12">
                    {youngTeacher.sections.map(sec => (
                            <div>
                                <h4 class="text-xs font-black uppercase tracking-widest text-blue-600 mb-6 flex items-center gap-2">
                                    <span class="w-2 h-2 bg-blue-600 rounded-full"></span>
                                    {sec.group}
                                </h4>
                                <ul class="space-y-4">
                                    {sec.links.map(link => (
                                            <li>
                                                <a href="#" class="text-sm font-bold text-slate-600 hover:text-blue-600 italic leading-snug flex gap-2">
                                                    <span class="text-slate-300">/</span> {link}
                                                </a>
                                            </li>
                                    ))}
                                </ul>
                            </div>
                    ))}
                </div>
            </div>

            <div id="master-school" class="bg-slate-50 rounded-[3rem] p-8 md:p-16 border border-slate-200">
                <div class="flex flex-col lg:flex-row gap-16">
                    <div class="lg:w-1/2">
                        <div class="flex items-center gap-4 mb-8">
                            <span class="text-4xl">{masterSchool.icon}</span>
                            <h2 class="text-3xl font-black uppercase italic text-slate-900">{masterSchool.title}</h2>
                        </div>
                        <h3 class="font-black text-slate-400 uppercase text-xs mb-6 tracking-widest">Матеріали занять:</h3>
                        <div class="space-y-3">
                            {masterSchool.materials.map(mat => (
                                    <div class="p-5 bg-white rounded-2xl border border-slate-200 hover:border-blue-400 transition-all shadow-sm flex justify-between items-center group">
                                        <span class="text-sm font-bold text-slate-700 leading-snug group-hover:text-blue-600">{mat}</span>
                                        <span class="text-slate-300 group-hover:text-blue-500">→</span>
                                    </div>
                            ))}
                        </div>
                    </div>
                    <div class="lg:w-1/2 space-y-12">
                        <div class="bg-white p-10 rounded-[2.5rem] border border-slate-200 shadow-xl">
                            <h3 class="font-black text-slate-900 uppercase italic mb-8 flex items-center gap-3">
                                <span class="w-1 h-6 bg-blue-600 rounded-full"></span>
                                Дидактичні зразки
                            </h3>
                            <ul class="space-y-6">
                                {masterSchool.samples.map(sample => (
                                        <li class="flex items-start gap-4">
                                            <div class="w-8 h-8 rounded-full bg-blue-50 text-blue-600 flex items-center justify-center text-xs font-black">✓</div>
                                            <span class="text-sm font-bold text-slate-600 italic leading-relaxed">{sample}</span>
                                        </li>
                                ))}
                            </ul>
                            <div class="mt-10 p-6 bg-blue-600 rounded-2xl text-white">
                                <p class="text-[10px] uppercase font-black opacity-80 mb-2 tracking-widest">План 2024-2025</p>
                                <p class="text-sm font-bold italic underline">План засідань Школи майстра-початківця (PDF)</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <section id="ppd-catalog" class="max-w-7xl mx-auto px-6 py-24 border-t border-slate-100">
        <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
            <div class="max-w-2xl">
                <span class="inline-block px-4 py-1 bg-amber-50 text-amber-600 rounded-lg text-xs font-black uppercase tracking-widest mb-4">Надбання ліцею</span>
                <h2 class="text-4xl md:text-5xl font-black text-slate-900 uppercase italic leading-tight">
                    Картотека <span class="text-amber-500">ППД</span>
                </h2>
                <p class="text-slate-500 mt-4 font-medium italic">Кращі практики, цифрові інструменти та авторські методики наших педагогів.</p>
            </div>
            <div class="hidden md:block">
                <div class="text-6xl grayscale opacity-20">📚</div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {ppdCatalog.map(item => (
                    <div class="group bg-white border border-slate-100 p-8 rounded-[2.5rem] shadow-sm hover:shadow-xl hover:border-amber-200 transition-all duration-500 flex flex-col justify-between">
                        <div>
                            <div class="flex justify-between items-start mb-6">
                                <div class="w-12 h-12 rounded-2xl bg-slate-50 flex items-center justify-center group-hover:bg-amber-500 group-hover:text-white transition-colors">
                                    <span class="text-xl">💎</span>
                                </div>
                                <div class="flex flex-wrap justify-end gap-2">
                                    {item.tags.map(tag => (
                                            <span class="text-[9px] uppercase font-black px-2 py-1 bg-slate-100 text-slate-400 rounded-md">#{tag}</span>
                                    ))}
                                </div>
                            </div>

                            <h4 class="text-sm font-black text-slate-400 uppercase tracking-widest mb-2 italic">{item.author}</h4>
                            <p class="text-xs text-blue-600 font-bold mb-4">{item.role}</p>
                            <p class="text-slate-800 font-bold italic leading-relaxed group-hover:text-amber-700 transition-colors">
                                «{item.topic}»
                            </p>
                        </div>

                        <div class="mt-8 pt-6 border-t border-slate-50 flex justify-between items-center">
                            <a href="#" class="text-[10px] font-black uppercase tracking-widest text-slate-900 group-hover:text-amber-500 transition-colors">Переглянути досвід</a>
                            <span class="text-slate-200 group-hover:translate-x-1 transition-transform">→</span>
                        </div>
                    </div>
            ))}
        </div>

        <div class="mt-16 p-10 bg-amber-50 rounded-[3rem] border border-amber-100 flex flex-col md:flex-row items-center gap-8">
            <div class="text-4xl">💡</div>
            <div class="flex-1 text-center md:text-left">
                <p class="text-amber-900 font-bold italic leading-relaxed">
                    Матеріали передового педагогічного досвіду постійно оновлюються. Кожен педагог може подати власну розробку до методичного кабінету для включення в картотеку після схвалення Методичною радою.
                </p>
            </div>
        </div>
    </section>

</PageLayout>