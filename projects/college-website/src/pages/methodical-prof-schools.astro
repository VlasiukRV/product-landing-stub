        "Сучасні педагогічні технології: цікаво та ефективно",
        "Від традиційного до інноваційного конструювання уроку",
        "Методика розробки дидактичних засобів",
        "Типи і види уроків виробничого навчання",
        "Навчально-методична документація майстра ЗП(ПТ)О",
        "Сучасні підходи до підготовки уроку",
        "Інструментарій сучасного уроку в/н"
    ],
    samples: ["Зразки інформаційних плакатів", "Зразки технологічних карток (9 зразків)", "Зразки карток нагадування"]
};

const ppdCatalog = [
    {
        author: "Безносюк В.І.",
        role: "Викладач інформатики та технології",
        topic: "Використання інтерактивної онлайн-дошки Miro та платформи Book Creator — як засіб активізації діяльнісного підходу у навчанні",
        tags: ["Miro", "Book Creator", "Цифровізація"]
    },
    {
        author: "Середенко О.В.",
        role: "Викладач проф-теорет підготовки",
        topic: "Google застосунки та учнівські проєкти як дієвий спосіб формування професійних компетенцій будівельників",
        tags: ["Google Workspace", "Будівництво", "Проєкти"]
    },
    {
        author: "Черноводський С.М.",
        role: "Майстер виробничого навчання",
        topic: "Барельєфна штукатурка на уроках професійно-практичної підготовки",
        tags: ["Майстерність", "Штукатурка", "Декор"]
    },
    {
        author: "Собчук К.І.",
        role: "Викладач хімії, біології і екології",
        topic: "Використання онлайн-дошки Padlet для індивідуальних завдань та проєктної роботи",
        tags: ["Padlet", "Природничі науки"]
    },
    {
