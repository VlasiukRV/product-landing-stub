---

<PageLayout title="Школи професійної майстерності"
            breadcrumbs={[{label: "Методична робота", href: "/methodical-work"}, {label: "Школи майстерності"}]}>

    <section class="max-w-7xl mx-auto px-6 py-16">
        <h1 class="text-4xl md:text-6xl font-black text-slate-900 uppercase italic mb-16 tracking-tight">
            Система <span class="text-blue-600">наставництва</span> <br/> та зростання
        </h1>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">

            <aside class="lg:col-span-3 hidden lg:block">
                <div class="sticky top-24 bg-white p-6 rounded-[2rem] shadow-xl border border-slate-100">
                    <nav id="scroll-nav" class="space-y-2">
                        <a href="#heads-school"
                           class="nav-link block px-4 py-3 rounded-xl hover:bg-slate-50 font-bold text-slate-700 hover:text-blue-600 transition-all">🎓
                            Школа голів МК</a>
                        <a href="#young-teacher"
                           class="nav-link block px-4 py-3 rounded-xl hover:bg-slate-50 font-bold text-slate-700 hover:text-blue-600 transition-all">🌱
                            Молодий педагог</a>
                        <a href="#master-school"
                           class="nav-link block px-4 py-3 rounded-xl hover:bg-slate-50 font-bold text-slate-700 hover:text-blue-600 transition-all">🛠️
                            Школа майстра</a>
                        <a href="#ppd-catalog"
                           class="nav-link block px-4 py-3 rounded-xl hover:bg-slate-50 font-bold text-slate-700 hover:text-blue-600 transition-all">💎
                            Картотека ППД</a>
                    </nav>
                </div>
            </aside>

            <main class="lg:col-span-9 space-y-20">

                <section id="heads-school" class="scroll-mt-28">
                    <div class="flex items-center justify-between mb-8">
                        <h2 class="text-2xl font-black uppercase italic text-slate-900 flex items-center gap-3">
                            <span class="text-3xl">{headsSchool.icon}</span>
                            {headsSchool.title}
                        </h2>
                        <div class="h-px flex-1 bg-slate-100 mx-8 hidden md:block"></div>
                        <div class="flex items-center gap-2">
                            <span class="w-2 h-2 bg-emerald-500 rounded-full animate-pulse"></span>
                            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest italic">Діюча структура</span>
                        </div>
                    </div>

                    <div class="columns-1 md:columns-2 gap-6 space-y-6">
                        <div class="break-inside-avoid bg-white border border-slate-100 rounded-[2.5rem] p-8 shadow-sm hover:shadow-md transition-shadow">
                            <h3 class="text-[10px] font-black uppercase text-blue-600 mb-6 tracking-widest flex items-center gap-2">
                                <span class="w-4 h-px bg-blue-600"></span> Нормативна база та плани
                            </h3>
                            <div class="space-y-3">
                                {headsSchool.docs.map(doc => (
                                        <a href="#" class="flex items-center gap-4 p-4 rounded-2xl bg-slate-50 border border-slate-50 hover:border-blue-200 hover:bg-white transition-all group">
                                            <div class="w-10 h-10 rounded-xl bg-white flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform text-xl">📄</div>
                                            <span class="text-xs font-bold text-slate-700 leading-snug">{doc.name}</span>
                                        </a>
                                ))}
                            </div>
                        </div>

                        <div class="break-inside-avoid bg-slate-900 rounded-[2.5rem] p-8 text-white shadow-xl shadow-slate-200">
                            <h3 class="text-[10px] font-black uppercase text-slate-500 mb-4 tracking-widest">Про проєкт</h3>
                            <p class="text-sm font-bold italic leading-relaxed text-slate-300">
                                «{headsSchool.desc}»
                            </p>
                            <div class="mt-8 pt-6 border-t border-white/10 flex justify-between items-center">
                                <span class="text-[9px] font-black uppercase tracking-widest text-blue-400">Методична рада</span>
                                <span class="text-xs opacity-50">2024</span>
                            </div>
                        </div>
                    </div>
                </section>

                <section id="young-teacher" class="scroll-mt-28">
                    <div class="flex items-center justify-between mb-8">
                        <h2 class="text-2xl font-black uppercase italic text-slate-900 flex items-center gap-3">
                            <span class="text-3xl">{youngTeacher.icon}</span>
                            {youngTeacher.title}
                        </h2>
                        <div class="h-px flex-1 bg-slate-100 mx-8 hidden md:block"></div>
                        <a href="#" class="text-[10px] font-black text-blue-600 uppercase border-b-2 border-blue-600 pb-1 hover:text-blue-800 transition-colors">Завантажити пакет ZIP</a>
                    </div>

                    <div class="columns-1 md:columns-2 lg:columns-3 gap-6 space-y-6">
                        {youngTeacher.sections.map((sec, index) => (
                                <div class={`break-inside-avoid rounded-[2.5rem] p-8 border ${index === 0 ? 'bg-blue-600 text-white border-transparent shadow-lg shadow-blue-100' : 'bg-white border-slate-100 shadow-sm'}`}>
                                    <h4 class={`text-[10px] font-black uppercase tracking-widest mb-6 ${index === 0 ? 'text-blue-200' : 'text-blue-600'}`}>
                                        {sec.group}
                                    </h4>
                                    <ul class="space-y-4">
                                        {sec.links.map(link => (
                                                <li>
                                                    <a href="#" class={`text-sm font-bold italic flex gap-2 transition-colors ${index === 0 ? 'text-white hover:text-blue-200' : 'text-slate-600 hover:text-blue-600'}`}>
                                                        <span class="opacity-30">/</span> {link}
                                                    </a>
                                                </li>
                                        ))}
                                    </ul>
                                </div>
                        ))}
                    </div>
                </section>

                <section id="master-school" class="scroll-mt-28">
                    <div class="flex items-center justify-between mb-8">
                        <h2 class="text-2xl font-black uppercase italic text-slate-900 flex items-center gap-3">
                            <span class="text-3xl">{masterSchool.icon}</span>
                            {masterSchool.title}
                        </h2>
                        <div class="h-px flex-1 bg-slate-100 mx-8 hidden md:block"></div>
                        <div class="flex flex-col items-end">
                            <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest italic">{masterSchool.desc}</span>
                        </div>
                    </div>

                    <div class="columns-1 md:columns-2 gap-6 space-y-6">

                        <div class="break-inside-avoid bg-white border border-slate-100 rounded-[2.5rem] p-8 shadow-sm hover:shadow-md transition-all">
                            <h3 class="text-[10px] font-black uppercase text-blue-600 mb-6 tracking-widest flex items-center gap-2">
                                <span class="w-4 h-px bg-blue-600"></span> Методичний інструментарій
                            </h3>
                            <div class="space-y-3">
                                {masterSchool.materials.map(mat => (
                                        <div class="p-4 bg-slate-50 rounded-2xl border border-slate-50 hover:border-blue-200 hover:bg-white transition-all group cursor-pointer flex justify-between items-center">
                                            <span class="text-sm font-bold text-slate-600 group-hover:text-slate-900 transition-colors leading-snug">{mat}</span>
                                            <span class="text-slate-300 group-hover:text-blue-500 group-hover:translate-x-1 transition-all text-lg">→</span>
                                        </div>
                                ))}
                            </div>
                        </div>

                        <div class="break-inside-avoid bg-slate-900 rounded-[2.5rem] p-8 text-white shadow-xl shadow-slate-200">
                            <div class="flex justify-between items-start mb-6">
                                <span class="text-[10px] font-black uppercase tracking-widest text-slate-500">Документація</span>
                                <span class="px-2 py-1 bg-blue-500 rounded text-[9px] font-black uppercase">2024-2025</span>
                            </div>
                            <h4 class="text-xl font-black italic uppercase mb-4">Навчальний графік засідань</h4>
                            <p class="text-slate-400 text-xs mb-8 leading-relaxed">Повний перелік тем, дат та відповідальних осіб доступний у форматі PDF.</p>
                            <a href="#" class="flex items-center justify-center gap-3 w-full py-4 bg-white/10 border border-white/10 rounded-2xl hover:bg-white hover:text-slate-900 transition-all font-black uppercase text-[10px] tracking-widest">
                                <span>Відкрити план засідань</span>
                                <span class="text-lg text-blue-400">⬇</span>
                            </a>
                        </div>

                        <div class="break-inside-avoid bg-emerald-50 border border-emerald-100 rounded-[2.5rem] p-8 shadow-sm">
                            <h3 class="text-[10px] font-black uppercase text-emerald-700 mb-6 tracking-widest flex items-center gap-2">
                                <span class="w-4 h-px bg-emerald-700"></span> Практичні кейси
                            </h3>
                            <div class="grid grid-cols-1 gap-3">
                                {masterSchool.samples.map(sample => (
                                        <div class="flex items-center gap-4 group">
                                            <div class="w-8 h-8 rounded-full bg-white text-emerald-600 flex items-center justify-center shadow-sm text-xs font-black shrink-0">
                                                ✓
                                            </div>
                                            <span class="text-sm font-bold text-emerald-900/80 italic leading-tight group-hover:text-emerald-900 transition-colors">{sample}</span>
                                        </div>
                                ))}
                            </div>
                        </div>

                    </div>
                </section>

                <section id="ppd-catalog" class="max-w-7xl mx-auto px-6 py-24 border-t border-slate-100">
                    <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6">
                        <div class="max-w-2xl">
                            <span class="inline-block px-4 py-1 bg-amber-50 text-amber-600 rounded-lg text-xs font-black uppercase tracking-widest mb-4">Надбання ліцею</span>
                            <h2 class="text-4xl md:text-5xl font-black text-slate-900 uppercase italic leading-tight">
                                Картотека <span class="text-amber-500">ППД</span>
                            </h2>
                            <p class="text-slate-500 mt-4 font-medium italic">Кращі практики, цифрові інструменти та
                                авторські
                                методики наших педагогів.</p>
                        </div>
                        <div class="hidden md:block">
                            <div class="text-6xl grayscale opacity-20">📚</div>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 gap-8">
                        {ppdCatalog.map(item => (
                                <div class="group bg-white border border-slate-100 p-8 rounded-[2.5rem] shadow-sm hover:shadow-xl hover:border-amber-200 transition-all duration-500 flex flex-col justify-between">
                                    <div>
                                        <div class="flex justify-between items-start mb-6">
                                            <div class="w-12 h-12 rounded-2xl bg-slate-50 flex items-center justify-center group-hover:bg-amber-500 group-hover:text-white transition-colors">
                                                <span class="text-xl">💎</span>
                                            </div>
                                            <div class="flex flex-wrap justify-end gap-2">
                                                {item.tags.map(tag => (
                                                        <span class="text-[9px] uppercase font-black px-2 py-1 bg-slate-100 text-slate-400 rounded-md">#{tag}</span>
                                                ))}
                                            </div>
                                        </div>

                                        <h4 class="text-sm font-black text-slate-400 uppercase tracking-widest mb-2 italic">{item.author}</h4>
                                        <p class="text-xs text-blue-600 font-bold mb-4">{item.role}</p>
                                        <p class="text-slate-800 font-bold italic leading-relaxed group-hover:text-amber-700 transition-colors">
                                            «{item.topic}»
                                        </p>
                                    </div>

                                    <div class="mt-8 pt-6 border-t border-slate-50 flex justify-between items-center">
                                        <a href="#"
                                           class="text-[10px] font-black uppercase tracking-widest text-slate-900 group-hover:text-amber-500 transition-colors">Переглянути
                                            досвід</a>
                                        <span class="text-slate-200 group-hover:translate-x-1 transition-transform">→</span>
                                    </div>
                                </div>
                        ))}
                    </div>

                    <div class="mt-16 p-10 bg-amber-50 rounded-[3rem] border border-amber-100 flex flex-col md:flex-row items-center gap-8">
                        <div class="text-4xl">💡</div>
                        <div class="flex-1 text-center md:text-left">
                            <p class="text-amber-900 font-bold italic leading-relaxed">
                                Матеріали передового педагогічного досвіду постійно оновлюються. Кожен педагог може
                                подати власну
                                розробку до методичного кабінету для включення в картотеку після схвалення
                                Методичною радою.
                            </p>
                        </div>
                    </div>
                </section>

            </main>

        </div>
    </section>


</PageLayout>

<script>
    const observerOptions = {
        root: null,
        rootMargin: '-20% 0px -70% 0px',
        threshold: 0
    };

    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            const id = entry.target.getAttribute('id');
            const navLink = document.querySelector(`.nav-link[href="#${id}"]`);

            if (entry.isIntersecting) {
                document.querySelectorAll('.nav-link').forEach(link => {
                    link.classList.remove('bg-blue-50', 'text-blue-600');
                    link.classList.add('text-slate-700');
                });
                if (navLink) {
                    navLink.classList.add('bg-blue-50', 'text-blue-600');
                    navLink.classList.remove('text-slate-700');
                }
            }
        });
    }, observerOptions);

    document.querySelectorAll('section[id]').forEach((section) => {
        observer.observe(section);
    });

</script>
