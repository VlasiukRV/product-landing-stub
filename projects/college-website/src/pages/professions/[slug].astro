---
// pages/professions/[slug].astro
import PageLayout from "../../layouts/PageLayout.astro";
import ProfessionGallery from "../../components/professions/ProfessionGallery.astro";
import professionsIndex from "../../data/professions/index.json";

export async function getStaticPaths() {
    const allProfessionFiles = import.meta.glob("../../data/professions/*.json");
    const paths = await Promise.all(
        professionsIndex.map(async (p) => {
            const filePath = `../../data/professions/${p.slug}.json`;
            const loadData = allProfessionFiles[filePath];
            if (!loadData) throw new Error(`Файл не знайдено: ${filePath}`);
            const data = await loadData() as any;
            return {
                params: { slug: p.slug },
                props: { profession: data.default },
            };
        })
    );
    return paths;
}

const { profession } = Astro.props;
---

<PageLayout

        breadcrumbs={[
            { label: "Професії", href: "/professions" },
            { label: profession.title }
        ]}
>
    <section class="relative py-20 overflow-hidden bg-slate-950">
        <div class="absolute inset-0 opacity-20">
            <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(circle_at_30%_30%,#2563eb_0,transparent_50%)]"></div>
        </div>

        <div class="max-w-5xl mx-auto px-6 relative z-10">
            <div class="flex flex-col md:flex-row gap-12 items-center">
                <div class="flex-1 text-center md:text-left">
                    <span class="inline-block px-4 py-1.5 bg-blue-600/20 text-blue-400 rounded-full text-xs font-black uppercase tracking-[0.2em] mb-6">
                        Навчальний напрямок
                    </span>
                    <h1 class="text-4xl md:text-6xl font-black text-white mb-6 leading-tight">
                        {profession.title}
                    </h1>
                    <p class="text-xl text-slate-400 leading-relaxed max-w-2xl">
                        {profession.shortDescription}
                    </p>
                </div>
                {profession.icon && (
                        <div class="w-40 h-40 md:w-64 md:h-64 bg-white/5 backdrop-blur-xl border border-white/10 rounded-[3rem] flex items-center justify-center shadow-2xl">
                            <img src={profession.icon} alt="" class="w-1/2 h-1/2 invert opacity-80" />
                        </div>
                )}
            </div>
        </div>
    </section>

    <section class="max-w-5xl mx-auto px-6 -mt-10 relative z-20">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">

            <div class="lg:col-span-4 order-2 lg:order-1">
                <div class="sticky top-24 space-y-6">
                    <div class="bg-white border border-slate-100 rounded-[2.5rem] p-8 shadow-xl shadow-slate-200/50">
                        <h3 class="text-lg font-bold text-slate-900 mb-6">Коротко про навчання</h3>
                        <div class="space-y-6">
                            <div class="flex items-start gap-4">
                                <div class="text-2xl">⏳</div>
                                <div>
                                    <p class="text-[10px] font-black uppercase tracking-widest text-slate-400">Термін</p>
                                    <p class="font-bold text-slate-700">3 роки (на базі 9 кл.)</p>
                                </div>
                            </div>
                            <div class="flex items-start gap-4">
                                <div class="text-2xl">🎓</div>
                                <div>
                                    <p class="text-[10px] font-black uppercase tracking-widest text-slate-400">Диплом</p>
                                    <p class="font-bold text-slate-700">Державного зразка</p>
                                </div>
                            </div>
                            <div class="flex items-start gap-4">
                                <div class="text-2xl">💰</div>
                                <div>
                                    <p class="text-[10px] font-black uppercase tracking-widest text-slate-400">Форма</p>
                                    <p class="font-bold text-slate-700">Бюджет / Стипендія</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <a href="/contacts" class="block p-8 bg-blue-600 rounded-[2.5rem] text-white hover:bg-blue-700 transition-colors shadow-xl shadow-blue-500/20 group">
                        <h4 class="font-black text-xl mb-2">Хочете вступити?</h4>
                        <p class="text-blue-100 text-sm mb-4">Наші консультанти розкажуть про умови прийому та необхідні документи.</p>
                        <span class="font-bold flex items-center gap-2">
                            Зв'язатися з нами <span class="group-hover:translate-x-2 transition-transform">→</span>
                        </span>
                    </a>
                </div>
            </div>

            <div class="lg:col-span-8 order-1 lg:order-2">
                <div class="bg-white border border-slate-100 rounded-[3rem] p-8 md:p-12 shadow-sm">
                    <article class="prose prose-slate prose-lg max-w-none
                        prose-headings:font-black prose-headings:tracking-tight
                        prose-p:text-slate-600 prose-p:leading-relaxed
                        prose-li:text-slate-600
                        prose-strong:text-slate-900">
                        <div set:html={profession.content} />
                    </article>

                    {profession.images && (
                            <div class="mt-16 pt-16 border-t border-slate-100">
                                <h3 class="text-2xl font-black text-slate-900 mb-8 tracking-tight italic">Виробнича практика та будні</h3>
                                <ProfessionGallery images={profession.images} />
                            </div>
                    )}
                </div>
            </div>
        </div>
    </section>
</PageLayout>