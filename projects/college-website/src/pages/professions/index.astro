---
// pages/professions/index.astro
import PageLayout from "../../layouts/PageLayout.astro";
import professions from "../../data/professions/index.json";
---

<PageLayout
        title="Оберіть своє майбутнє"
        breadcrumbs={[{ label: "Головна", href: "/" }, { label: "Професії" }]}
>
    <section class="max-w-7xl mx-auto px-6 py-12">
        <div class="text-center mb-16">
            <h1 class="text-4xl md:text-5xl font-black text-slate-900 tracking-tight mb-4">
                Професії та <span class="text-blue-600">спеціальності</span>
            </h1>
            <p class="text-lg text-slate-500 max-w-2xl mx-auto leading-relaxed">
                Ми готуємо кваліфікованих робітників за найбільш затребуваними напрямками на ринку праці. Оберіть фах, що змінить ваше життя.
            </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {professions.map((p) => (
                    <div class="group relative bg-white border border-slate-100 rounded-[2.5rem] p-8 shadow-sm hover:shadow-2xl hover:shadow-blue-500/10 transition-all duration-500 flex flex-col min-h-[400px]">

                        <div class="mb-6">
                            <div class="relative z-10 w-14 h-14 mb-6 rounded-2xl bg-slate-50 flex items-center justify-center text-3xl shadow-inner group-hover:scale-110 group-hover:bg-white group-hover:shadow-lg transition-all duration-500 origin-left">
                                {p.icon}
                            </div>
                            <h3 class="text-2xl font-black text-slate-900 leading-tight mb-3">
                                {p.title}
                            </h3>
                            <p class="text-slate-500 text-sm leading-relaxed line-clamp-3">
                                {p.shortDescription}
                            </p>
                        </div>

                        <div class="flex flex-wrap gap-2 mb-8">
                            <span class="px-3 py-1 bg-slate-50 text-[10px] font-bold text-slate-400 uppercase tracking-widest rounded-full">3 роки навчання</span>
                            <span class="px-3 py-1 bg-emerald-50 text-[10px] font-bold text-emerald-600 uppercase tracking-widest rounded-full">Є попит</span>
                        </div>

                        <div class="mt-auto space-y-4">
                            <div class="space-y-2">
                                {p.subLinks && p.subLinks.map((link) => (
                                        <a href={link.href} class="flex items-center text-sm font-semibold text-slate-600 hover:text-blue-600 transition-colors">
                                            <span class="w-1 h-1 rounded-full bg-blue-400 mr-2"></span>
                                            {link.label}
                                        </a>
                                ))}
                            </div>

                            <a href={`/professions/${p.slug}`} class="flex items-center justify-between w-full p-4 bg-slate-900 text-white rounded-2xl font-bold text-sm group-hover:bg-blue-600 transition-colors duration-300">
                                Детальніше про фах
                                <span class="text-xl group-hover:translate-x-1 transition-transform">→</span>
                            </a>
                        </div>
                    </div>
            ))}
        </div>
    </section>
</PageLayout>