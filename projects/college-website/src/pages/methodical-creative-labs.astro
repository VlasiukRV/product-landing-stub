---
import PageLayout from "../layouts/PageLayout.astro";

const labs = [
    {
        id: "culinary-design",
        title: "Школа кулінарного дизайну",
        shortTitle: "Кулінарний дизайн",
        icon: "🎨",
        goal: "Вивчення та оволодіння теоретичними знаннями та практичними навиками з оформлення кулінарної та кондитерської продукції, сучасного дизайну та естетики страв.",
        tasks: [
            "Отримання знань з основ оформлення харчових продуктів",
            "Розроблення нових технологій оздоблення кулінарних виробів",
            "Вивчення дії окремих компонентів та їх поєднання",
            "Оволодіння методами поєднання кольорових гам",
            "Створення нових дизайнерських рішень для оформлення страв"
        ],
        docs: [
            { label: "Програма школи", href: "#" },
            { label: "План роботи 2024/2025 н.р.", href: "#" },
            { label: "План роботи 2023/2024 н.р.", href: "#" }
        ]
    },
    {
        id: "pro-growth",
        title: "Школа професійного зростання",
        shortTitle: "Проф. зростання",
        icon: "📈",
        goal: "Підвищення цифрової компетентності викладачів професійно-теоретичної підготовки та підготовка їх до роботи із застосуванням сучасних цифрових освітніх ресурсів.",
        tasks: [
            "Удосконалення розуміння особливостей цифрового навчання",
            "Поглиблення знань із застосування цифрових сервісів",
            "Розвиток навичок створення власних навчальних матеріалів",
            "Мотивація до навчання впродовж життя за допомогою ІКТ"
        ],
        docs: [
            { label: "Положення про школу", href: "#" },
            { label: "План роботи 2024/2025 н.р.", href: "#" },
            { label: "План роботи 2023/2024 н.р.", href: "#" }
        ]
    },
    {
        id: "ppd",
        title: "Школа передового досвіду (ППД)",
        shortTitle: "Передовий досвід",
        icon: "🌟",
        goal: "Прискорення трансформації передового педагогічного досвіду в широку практику та сприяння розвитку професійної майстерності педагогів.",
        tasks: [
            "Пропаганда перспективних моделей досвіду",
            "Інформаційно-методичний супровід проблем ліцею",
            "Створення умов для практичного засвоєння нових технологій",
            "Моделювання навчальних занять та позакласних заходів"
        ],
        docs: [
            { label: "Положення про школу ППД", href: "#" },
            { label: "План роботи 2023/2024 н.р.", href: "#" },
            { label: "План роботи 2022/2023 н.р.", href: "#" }
        ]
    }
];

const projects = [
    {
        id: "authentic-dishes",
        title: "Автентичні кулінарні страви",
        meta: "Пошуковий проєкт",
        desc: "Проєкт спрямований на творчу взаємодію учасників щодо вивчення кулінарної спадщини різних регіонів України.",
        goal: "Виховання творчого кухаря, що вміє відтворювати етнічну кулінарію.",
        features: ["Збірка рецептів", "Апробація під час ДКА", "Патріотизм"]
    },
    {
        id: "traditional-bakery",
        title: "Українська традиційна випічка",
        meta: "Дослідницький проєкт",
        desc: "Вивчення традицій борошняних виробів нашого народу та впровадження їх у сучасний освітній процес.",
        goal: "Розвивати навички роботи в команді над створенням автентичних страв.",
        features: ["Пошук рецептур", "Цифрова фіксація", "Майстер-класи"]
    }
];
---

<PageLayout title="Творчі лабораторії" breadcrumbs={[{label: "Методична робота", href: "/methodical-work"}, {label: "Творчі лабораторії"}]}>

    <section class="bg-slate-900 pt-24 pb-64 text-white relative overflow-hidden">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_120%,rgba(37,99,235,0.15),transparent)]"></div>
        <div class="max-w-7xl mx-auto px-6 relative z-10 text-center md:text-left">
            <span class="inline-block px-4 py-1.5 bg-blue-500 text-white rounded-xl text-[10px] font-black uppercase tracking-[0.2em] mb-6">Innovation Hub</span>
            <h1 class="text-5xl md:text-7xl font-black mb-8 uppercase italic tracking-tighter leading-[0.85]">
                Творчі <span class="text-blue-500 text-shadow-glow">лабораторії</span>
            </h1>
            <p class="text-slate-400 max-w-2xl text-lg font-medium italic leading-relaxed mx-auto md:mx-0">
                Простір для експериментів, де традиції поєднуються з цифровими технологіями, а досвід перетворюється на інновації.
            </p>
        </div>
    </section>

    <div class="max-w-7xl mx-auto px-6 -mt-40 relative z-30 pb-24">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">

            <aside class="lg:col-span-3 hidden lg:block sticky top-24 space-y-4">
                <div class="bg-white p-6 rounded-[2.5rem] shadow-xl border border-slate-100">
                    <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-6 px-4">Навігація:</p>
                    <nav id="labs-nav" class="space-y-1">
                        <p class="px-4 text-[9px] font-black text-blue-600 uppercase mb-2">Школи:</p>
                        {labs.map((lab) => (
                                <a
                                        href={`#${lab.id}`}
                                        class="nav-link flex items-center gap-3 px-4 py-3 rounded-2xl font-bold text-slate-600 hover:bg-blue-50 hover:text-blue-600 transition-all group"
                                >
                                    <span class="w-1.5 h-1.5 rounded-full bg-slate-300 group-hover:bg-blue-600 transition-colors"></span>
                                    <span class="text-xs italic">{lab.shortTitle}</span>
                                </a>
                        ))}
                        <div class="h-px bg-slate-100 my-4 mx-4"></div>
                        <p class="px-4 text-[9px] font-black text-emerald-600 uppercase mb-2">Проєкти:</p>
                        <a href="#projects" class="nav-link flex items-center gap-3 px-4 py-3 rounded-2xl font-bold text-slate-600 hover:bg-emerald-50 hover:text-emerald-600 transition-all group">
                            <span class="w-1.5 h-1.5 rounded-full bg-slate-300 group-hover:bg-emerald-600 transition-colors"></span>
                            <span class="text-xs italic">Дослідницькі проєкти</span>
                        </a>
                    </nav>
                </div>

                <div class="bg-slate-900 p-8 rounded-[2.5rem] text-white shadow-lg relative overflow-hidden group">
                    <div class="absolute -right-4 -bottom-4 text-6xl opacity-10 italic font-black">LAB</div>
                    <h4 class="text-xs font-black uppercase tracking-widest mb-2 opacity-80 italic">Методична рада</h4>
                    <p class="text-[10px] font-medium leading-relaxed opacity-70 italic">Всі проєкти затверджені методичною радою ліцею на 2025/2026 н.р.</p>
                </div>
            </aside>

            <main class="lg:col-span-9 space-y-16">

                {labs.map((lab) => (
                        <section id={lab.id} class="scroll-mt-40 bg-white border border-slate-100 rounded-[3rem] shadow-soft overflow-hidden group hover:shadow-xl transition-all">
                            <div class="grid grid-cols-1 xl:grid-cols-12">
                                <div class="xl:col-span-8 p-8 md:p-12">
                                    <div class="flex items-center gap-5 mb-8">
                                        <div class="w-16 h-16 bg-slate-50 rounded-2xl flex items-center justify-center text-4xl shadow-inner group-hover:scale-110 transition-transform">
                                            {lab.icon}
                                        </div>
                                        <h2 class="text-3xl font-black text-slate-900 uppercase italic leading-tight">{lab.title}</h2>
                                    </div>

                                    <div class="space-y-8">
                                        <div class="relative">
                                            <div class="absolute -left-4 top-0 bottom-0 w-1 bg-blue-600 rounded-full opacity-20"></div>
                                            <h3 class="text-[10px] font-black uppercase tracking-widest text-blue-600 mb-3">Мета діяльності</h3>
                                            <p class="text-lg font-black leading-snug italic text-slate-800">
                                                «{lab.goal}»
                                            </p>
                                        </div>

                                        <div>
                                            <h3 class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-5 flex items-center gap-2">
                                                <span class="w-4 h-px bg-slate-200"></span> Основні завдання
                                            </h3>
                                            <ul class="grid grid-cols-1 md:grid-cols-2 gap-y-4 gap-x-8">
                                                {lab.tasks.map(task => (
                                                        <li class="flex gap-3 text-xs font-bold text-slate-500 italic leading-relaxed group/item">
                                                            <span class="text-blue-500 group-hover/item:translate-x-1 transition-transform">→</span>
                                                            {task}
                                                        </li>
                                                ))}
                                            </ul>
                                        </div>
                                    </div>
                                </div>

                                <div class="xl:col-span-4 bg-slate-50 p-8 md:p-12 border-l border-slate-100 flex flex-col">
                                    <h3 class="text-xs font-black text-slate-900 uppercase italic mb-6 tracking-widest">Документація</h3>
                                    <div class="space-y-3 flex-grow">
                                        {lab.docs.map(doc => (
                                                <a href={doc.href} class="flex items-center justify-between p-4 bg-white rounded-2xl border border-slate-200 hover:border-blue-400 hover:shadow-md transition-all group/link">
                                                    <span class="text-xs font-black text-slate-700 group-hover/link:text-blue-600 italic">{doc.label}</span>
                                                    <div class="w-8 h-8 rounded-full bg-slate-50 flex items-center justify-center text-[10px] font-black text-slate-300 group-hover/link:bg-blue-600 group-hover/link:text-white transition-all">↓</div>
                                                </a>
                                        ))}
                                    </div>
                                    <div class="mt-8 p-6 bg-slate-900 rounded-[2rem] text-white overflow-hidden relative">
                                        <div class="relative z-10 text-center">
                                            <p class="text-[9px] uppercase font-black tracking-[0.2em] opacity-50 mb-1">Статус проєкту</p>
                                            <p class="text-sm font-black italic uppercase text-blue-400">Впровадження</p>
                                        </div>
                                        <div class="absolute -right-4 -bottom-4 text-4xl opacity-10 font-black">OK</div>
                                    </div>
                                </div>
                            </div>
                        </section>
                ))}

                <section id="projects" class="scroll-mt-40">
                    <div class="flex items-center gap-6 mb-12">
                        <h2 class="text-3xl md:text-5xl font-black text-slate-900 uppercase italic tracking-tighter">Дослідницькі <span class="text-blue-600">проєкти</span></h2>
                        <div class="h-px flex-grow bg-slate-200"></div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        {projects.map(project => (
                                <div class="bg-white p-10 rounded-[3rem] border border-slate-100 shadow-soft hover:shadow-2xl transition-all group relative overflow-hidden">
                                    <div class="absolute top-0 right-0 w-32 h-32 bg-emerald-50 rounded-full -mr-16 -mt-16 group-hover:scale-110 transition-transform"></div>

                                    <div class="relative z-10">
                                        <div class="flex justify-between items-start mb-8">
                                        <span class="px-4 py-1.5 bg-emerald-600 text-white rounded-xl text-[9px] font-black uppercase tracking-widest">
                                            {project.meta}
                                        </span>
                                            <span class="text-3xl">🥘</span>
                                        </div>
                                        <h3 class="text-2xl font-black text-slate-900 mb-4 italic uppercase leading-none">{project.title}</h3>
                                        <p class="text-slate-500 text-xs font-medium leading-relaxed mb-8 italic">{project.desc}</p>

                                        <div class="p-6 bg-slate-50 rounded-[2rem] border border-slate-100 mb-8">
                                            <h4 class="text-[9px] font-black text-emerald-600 uppercase tracking-widest mb-2">Головна мета:</h4>
                                            <p class="text-sm font-black text-slate-800 italic leading-snug">{project.goal}</p>
                                        </div>

                                        <div class="flex flex-wrap gap-2">
                                            {project.features.map(f => (
                                                    <span class="px-4 py-1.5 bg-white border border-slate-200 rounded-xl text-[9px] font-black text-slate-400 uppercase italic">
                                                #{f}
                                            </span>
                                            ))}
                                        </div>
                                    </div>
                                </div>
                        ))}
                    </div>
                </section>

                <section class="p-12 bg-blue-600 rounded-[3.5rem] text-center text-white relative overflow-hidden shadow-2xl shadow-blue-200">
                    <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10"></div>
                    <div class="relative z-10">
                        <h3 class="text-3xl font-black uppercase italic mb-4">Бажаєте долучитися?</h3>
                        <p class="text-blue-100 mb-10 max-w-xl mx-auto font-medium italic">Ми завжди раді ініціативним педагогам, які прагнуть розвивати автентичну кулінарію та цифрову освіту.</p>
                        <a href="/methodical-cabinet" class="inline-block px-12 py-5 bg-white text-blue-600 rounded-2xl font-black uppercase text-xs tracking-[0.2em] hover:bg-slate-900 hover:text-white transition-all transform hover:-translate-y-1">
                            Подати заявку методисту
                        </a>
                    </div>
                </section>

            </main>
        </div>
    </div>
</PageLayout>

<style>
    html {
        scroll-behavior: smooth;
    }
    .shadow-soft {
        box-shadow: 0 20px 50px -20px rgba(0,0,0,0.05);
    }
    .text-shadow-glow {
        text-shadow: 0 0 30px rgba(37, 99, 235, 0.2);
    }

    .nav-link.active {
        background-color: #eff6ff;
        color: #2563eb;
    }
    .nav-link.active span:first-child {
        background-color: #2563eb;
        transform: scale(1.5);
    }
</style>

<script is:inline>
    const sections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('.nav-link');

    window.addEventListener('scroll', () => {
        let current = '';
        sections.forEach(section => {
            const sectionTop = section.offsetTop;
            if (pageYOffset >= (sectionTop - 200)) {
                current = section.getAttribute('id');
            }
        });

        navLinks.forEach(link => {
            link.classList.remove('active');
            if (link.getAttribute('href').includes(current)) {
                link.classList.add('active');
            }
        });
    });
</script>