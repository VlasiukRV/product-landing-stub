---
import PageLayout from "../layouts/PageLayout.astro";
import GridLinks from "../components/blocks/GridLinks.astro";

const focusAreas = [
    {
        title: "Методичні комісії",
        desc: "Організація роботи викладачів за напрямками підготовки та обмін досвідом.",
        icon: "👥",
        color: "blue"
    },
    {
        title: "Підвищення кваліфікації",
        desc: "Курси, атестація та професійний розвиток педагогів ліцею.",
        icon: "📈",
        color: "emerald"
    },
    {
        title: "Інноваційні технології",
        desc: "Використання цифрових інструментів та сучасних методик навчання.",
        icon: "💡",
        color: "amber"
    },
    {
        title: "Методичні матеріали",
        desc: "База розробок, рекомендацій та актуальних навчальних ресурсів.",
        icon: "📚",
        color: "indigo"
    }
];

const navigationLinks = [
    { title: "Методичний кабінет", description: "Документація, положення та плани", href: "/methodical-cabinet", icon: "🏢" },
    { title: "Склад МК", description: "Голови та члени методичних комісій", href: "/methodical-commissions", icon: "👥" },
    { title: "Творчі лабораторії", description: "Інновації та експериментальні проєкти", href: "/methodical-creative-labs", icon: "🧪" },
    { title: "Школа голів МК", description: "Координація роботи підрозділів", href: "/methodical-prof-schools#heads-school", icon: "🎓" },
    { title: "Школа ППД", description: "Передовий педагогічний досвід", href: "/methodical-prof-schools#ppd-catalog", icon: "💡" },
    { title: "Школа молодого педагога", description: "Адаптація та підтримка нових кадрів", href: "/methodical-prof-schools#young-teacher", icon: "🌱" },
    { title: "Школа майстра в/н", description: "Розвиток майстрів виробничого навчання", href: "/methodical-prof-schools#master-school", icon: "🛠️" }
];
---

<PageLayout title="Методична робота" breadcrumbs={[{label: "Методична робота"}]}>

    <section class="max-w-7xl mx-auto px-6 py-16 md:py-24">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
            <div class="space-y-8">
                <div>
                    <span class="inline-block px-4 py-1.5 bg-blue-50 text-blue-600 rounded-full text-sm font-bold uppercase tracking-wider mb-4">
                        Освітній простір
                    </span>
                    <h1 class="text-5xl md:text-7xl font-black text-slate-900 tracking-tight leading-[1.1]">
                        Лабораторія <br/>
                        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-600">педагогічного пошуку</span>
                    </h1>
                </div>

                <p class="text-xl text-slate-600 leading-relaxed max-w-xl">
                    Ми не просто вчимо — ми створюємо середовище, де кожен викладач стає дослідником, а кожен урок — кроком до професійної досконалості.
                </p>

                <div class="flex flex-wrap gap-4">
                    <div class="flex items-center gap-3 px-6 py-4 bg-white shadow-soft rounded-2xl border border-slate-100">
                        <span class="text-2xl">✨</span>
                        <div>
                            <div class="font-black text-slate-900 leading-none">10+</div>
                            <div class="text-xs text-slate-500 uppercase font-bold">Комісій</div>
                        </div>
                    </div>
                    <div class="flex items-center gap-3 px-6 py-4 bg-white shadow-soft rounded-2xl border border-slate-100">
                        <span class="text-2xl">🏆</span>
                        <div>
                            <div class="font-black text-slate-900 leading-none">Методична</div>
                            <div class="text-xs text-slate-500 uppercase font-bold">Рада</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="relative">
                <div class="absolute -inset-4 bg-gradient-to-tr from-blue-600/20 to-emerald-600/20 blur-3xl rounded-full"></div>
                <div class="relative bg-slate-900 rounded-[3rem] p-10 shadow-2xl overflow-hidden">
                    <div class="absolute top-0 right-0 w-32 h-32 bg-white/5 rounded-full -mr-16 -mt-16"></div>
                    <h3 class="text-white font-black text-2xl mb-8 flex items-center gap-3">
                        <span class="w-2 h-8 bg-blue-500 rounded-full"></span>
                        Пріоритети року
                    </h3>
                    <div class="space-y-6">
                        <div class="flex gap-5 group">
                            <div class="flex-none w-10 h-10 rounded-xl bg-blue-500/20 flex items-center justify-center text-blue-400 font-black group-hover:bg-blue-500 group-hover:text-white transition-all">01</div>
                            <p class="text-slate-300 font-medium italic leading-snug">"Розвиток цифрових компетенцій педагогічних працівників"</p>
                        </div>
                        <div class="flex gap-5 group">
                            <div class="flex-none w-10 h-10 rounded-xl bg-emerald-500/20 flex items-center justify-center text-emerald-400 font-black group-hover:bg-emerald-500 group-hover:text-white transition-all">02</div>
                            <p class="text-slate-300 font-medium italic leading-snug">"Підвищення якості освітнього процесу через інновації"</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="bg-slate-50 py-24 border-y border-slate-100">
        <div class="max-w-7xl mx-auto px-6">
            <div class="text-center max-w-3xl mx-auto mb-16">
                <h2 class="text-3xl md:text-4xl font-black text-slate-900 mb-4">Напрямки нашої діяльності</h2>
                <p class="text-slate-500 uppercase tracking-widest text-sm font-bold">Системний підхід до розвитку освіти</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                {focusAreas.map(area => (
                        <div class="group bg-white p-10 rounded-[2.5rem] border border-slate-200/60 shadow-sm hover:shadow-2xl hover:-translate-y-2 transition-all duration-500">
                            <div class="w-16 h-16 bg-slate-50 rounded-2xl flex items-center justify-center text-4xl mb-8 group-hover:scale-110 transition-transform duration-500 shadow-inner">
                                {area.icon}
                            </div>
                            <h4 class="font-black text-xl text-slate-900 mb-4 uppercase italic leading-tight">{area.title}</h4>
                            <p class="text-slate-500 text-sm leading-relaxed">{area.desc}</p>
                        </div>
                ))}
            </div>
        </div>
    </section>

    <section class="max-w-5xl mx-auto px-6 py-24">
        <div class="relative p-12 md:p-16 bg-white border border-slate-100 rounded-[3rem] shadow-soft overflow-hidden">
            <div class="absolute top-0 right-0 p-12 text-slate-50 text-9xl font-black pointer-events-none">2026</div>
            <div class="relative z-10">
                <h2 class="text-2xl md:text-3xl font-black text-slate-900 mb-8 flex items-center gap-4">
                    <span class="w-12 h-1 bg-blue-600 rounded-full"></span>
                    Єдина науково-методична проблема
                </h2>
                <div class="p-8 bg-blue-50/50 rounded-3xl border border-blue-100/50">
                    <p class="text-xl md:text-2xl text-slate-800 font-bold leading-snug italic">
                        «Розвиток та вдосконалення цифрових компетенцій педагогічних працівників, як один з важливих етапів покращення якості освітнього процесу»
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24">
        <div class="max-w-7xl mx-auto px-6">
            <h2 class="text-3xl font-black text-slate-900 mb-16 text-center uppercase italic tracking-tight">
                Структура методичної служби
            </h2>

                <GridLinks
                        columns={3}
                        items={navigationLinks}
                />

        </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 pb-24">
        <div class="p-12 bg-slate-900 rounded-[3rem] text-white relative overflow-hidden group">
            <div class="absolute inset-0 bg-[url('/grid.svg')] opacity-10"></div>
            <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">
                <div class="max-w-xl text-center md:text-left">
                    <h3 class="text-3xl font-black mb-4">На допомогу педагогу</h3>
                    <p class="text-slate-400">
                        Всі необхідні шаблони, рекомендації щодо атестації та навчальні матеріали зібрані в нашому цифровому кабінеті.
                    </p>
                </div>
                <div class="flex flex-wrap justify-center gap-4">
                    <a href="/methodical-cabinet" class="px-8 py-4 bg-blue-600 hover:bg-blue-500 rounded-2xl font-black uppercase text-xs tracking-widest transition-all shadow-lg shadow-blue-600/20">
                        Методична скарбничка
                    </a>
                    <a href="/methodical-prof-schools#ppd-catalog" class="px-8 py-4 bg-white/10 hover:bg-white/20 rounded-2xl font-black uppercase text-xs tracking-widest transition-all backdrop-blur-md">
                        Досвід колег
                    </a>
                </div>
            </div>
        </div>
    </section>

</PageLayout>

<style>
    .shadow-soft {
        box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.05);
    }
</style>