---
// src/components/blocks/GridLinks.astro

interface Item {
    title: string;
    href?: string;
    description?: string;
    icon?: string;
    disabled?: boolean;
}

const {
    items = [],
    columns = 2,
    title
} = Astro.props;

const gridCols = {
    1: "grid-cols-1",
    2: "grid-cols-1 md:grid-cols-2",
    3: "grid-cols-1 md:grid-cols-3",
    4: "grid-cols-2 lg:grid-cols-4"
};
---

<section class="py-12">
    {title && (
            <div class="flex flex-col md:flex-row md:items-end gap-4 mb-12">
                <div class="space-y-1">
                    <span class="text-[10px] font-black uppercase tracking-[0.3em] text-blue-600 italic">Навігація</span>
                    <h2 class="text-3xl md:text-4xl font-black text-slate-900 uppercase italic tracking-tighter">
                        {title}
                    </h2>
                </div>
                <div class="flex-1 h-px bg-slate-100 mb-2 hidden md:block"></div>
            </div>
    )}

    <div class={`grid ${gridCols[columns] || gridCols[2]} gap-8`}>
        {items.map((item) => {
            const isLink = !!item.href && !item.disabled;
            const Tag = isLink ? 'a' : 'div';

            return (
                    <Tag
                            href={isLink ? item.href : undefined}
                            class={`
                        group relative p-8 rounded-[2.5rem] border transition-all duration-500 overflow-hidden
                        ${isLink
                                ? "bg-white border-slate-100 shadow-soft hover:shadow-2xl hover:-translate-y-2 cursor-pointer"
                                : "bg-slate-50 border-slate-200 opacity-50 cursor-not-allowed"}
                    `}
                    >
                        {/* Фоновий декор для активних посилань */}
                        {isLink && (
                                <div class="absolute top-0 right-0 w-32 h-32 bg-slate-50 rounded-full -mr-16 -mt-16 transition-transform duration-700 group-hover:scale-150 group-hover:bg-blue-50/50"></div>
                        )}

                        {/* ICON */}
                        {item.icon && (
                                <div class="relative z-10 w-14 h-14 mb-6 rounded-2xl bg-slate-50 flex items-center justify-center text-3xl shadow-inner group-hover:scale-110 group-hover:bg-white group-hover:shadow-lg transition-all duration-500 origin-left">
                                    {item.icon}
                                </div>
                        )}

                        {/* CONTENT */}
                        <div class="relative z-10 space-y-3">
                            <h3 class={`font-black text-xl uppercase italic tracking-tight leading-tight transition-colors ${isLink ? "text-slate-800 group-hover:text-blue-600" : "text-slate-400"}`}>
                                {item.title}
                            </h3>

                            {item.description && (
                                    <p class={`text-sm leading-relaxed line-clamp-2 italic font-medium transition-colors ${isLink ? "text-slate-500 group-hover:text-slate-600" : "text-slate-400"}`}>
                                        {item.description}
                                    </p>
                            )}
                        </div>

                        {/* Стрілка дії */}
                        {isLink && (
                                <div class="mt-8 flex items-center gap-2">
                                    <div class="w-8 h-8 rounded-full bg-slate-900 flex items-center justify-center text-white transform -translate-x-4 opacity-0 group-hover:translate-x-0 group-hover:opacity-100 transition-all duration-500">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                                        </svg>
                                    </div>
                                    <span class="text-[10px] font-black uppercase tracking-widest text-blue-600 opacity-0 group-hover:opacity-100 transition-opacity duration-700 delay-100">
                                Відкрити розділ
                            </span>
                                </div>
                        )}

                        {/* Невеликий індикатор деактивованого стану */}
                        {!isLink && (
                                <div class="absolute top-4 right-4 px-3 py-1 bg-slate-200 rounded-full text-[8px] font-black uppercase tracking-widest text-slate-500">
                                    Незабаром
                                </div>
                        )}
                    </Tag>
            );
        })}
    </div>
</section>

<style>
    .shadow-soft {
        box-shadow: 0 10px 40px -15px rgba(0,0,0,0.06);
    }
</style>