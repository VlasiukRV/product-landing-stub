---
// components/blocks/QuickLinks.astro
const { links = [] } = Astro.props;
---

<div class="grid grid-cols-2 md:grid-cols-4 gap-6">
    {links.map(link => (
            <a href={link.href} class="group relative bg-white border border-slate-100 p-6 rounded-2xl shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                <div class="text-3xl mb-4 transform group-hover:scale-125 transition-transform duration-300">{link.icon}</div>
                <div class="font-bold text-slate-700 group-hover:text-blue-600">{link.title}</div>
                <div class="absolute bottom-4 right-4 opacity-0 group-hover:opacity-100 transition-opacity">
                    <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
                </div>
            </a>

    ))}
</div>