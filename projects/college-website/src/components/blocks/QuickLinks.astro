---
// components/blocks/QuickLinks.astro
const { items = [] } = Astro.props;
---

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    {items.map((item, index) => (
            <a
                    href={item.href}
                    class="group relative overflow-hidden bg-white border border-slate-100 p-8 rounded-[2.5rem] shadow-soft hover:shadow-2xl hover:-translate-y-2 transition-all duration-500"
            >
                <div class="absolute -right-4 -bottom-4 text-8xl font-black text-slate-50 opacity-[0.03] group-hover:opacity-[0.07] group-hover:scale-110 transition-all duration-500 italic pointer-events-none">
                    {index + 1}
                </div>

                <div class="absolute top-0 left-0 w-full h-1.5 bg-gradient-to-r from-blue-500 to-emerald-500 transform -translate-x-full group-hover:translate-x-0 transition-transform duration-500"></div>

                <div class="relative z-10">
                    <div class="w-16 h-16 mb-8 rounded-2xl bg-slate-50 flex items-center justify-center text-4xl shadow-inner group-hover:bg-blue-600 group-hover:text-white group-hover:rotate-[10deg] transition-all duration-500">
                        {item.icon}
                    </div>

                    <h3 class="text-xl font-black text-slate-900 uppercase italic leading-tight mb-2 group-hover:text-blue-600 transition-colors">
                        {item.title}
                    </h3>

                    <p class="text-xs font-bold text-slate-400 uppercase tracking-widest flex items-center gap-2 group-hover:text-slate-600">
                        Перейти
                        <span class="w-8 h-px bg-slate-200 group-hover:w-12 group-hover:bg-blue-500 transition-all duration-500"></span>
                    </p>
                </div>

                <div class="absolute bottom-8 right-8 w-10 h-10 rounded-full border border-slate-100 flex items-center justify-center opacity-0 group-hover:opacity-100 group-hover:translate-x-2 transition-all duration-500">
                    <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                    </svg>
                </div>
            </a>
    ))}
</div>

<style>
    .shadow-soft {
        box-shadow: 0 10px 40px -15px rgba(0,0,0,0.05);
    }
</style>