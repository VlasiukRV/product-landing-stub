---
import NavEntry from "./NavEntry.astro";

const nav = [
    {
        label: "Про заклад",
        children: [
            {label: "Історія", href: "/history"},
            {label: "Колектив", href: "/staff"}
        ]
    },
    {
        label: "Навчання",
        children: [
            {label: "Професії", href: "/professions"},
            {label: "Методична робота", href: "/methodical-work"}
        ]
    },
    {
        label: "Студенту",
        children: [
            {label: "Виховна робота", href: "/education"},
            {label: "Психолог", href: "/psychology"},
            {label: "Спорт", href: "/sports"},
            {label: "Кар'єра", href: "/career"},
            {label: "Розклад", href: "/schedule"}
        ]
    },

    {label: "Контакти", href: "/contacts"}
];
---

<header class="w-full border-b bg-white sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-lg bg-blue-600 flex items-center justify-center text-white font-bold">БПЛ</div>
            <span class="font-bold text-gray-900">Благовіщенський професійний ліцей</span>
        </a>

        <nav class="hidden md:flex items-center gap-6">
            {nav.map(item => (
                    <NavEntry item={item} />
            ))}
        </nav>

        <div class="flex items-center gap-3">
            <a href="/admin" class="hidden sm:inline-flex text-sm px-3 py-1.5 rounded-md border hover:bg-gray-100">Адмінка</a>
            <button id="menuBtn" class="md:hidden p-2 rounded-md border">☰</button>
        </div>
    </div>

    <div id="mobileMenu" class="md:hidden hidden border-t bg-white">
        <div class="px-6 py-4 flex flex-col gap-2">
            {nav.map(item => (
                    <NavEntry item={item} isMobile={true} />
            ))}
        </div>
    </div>
</header>

<script>
    const menuBtn = document.getElementById('menuBtn');
    const mobileMenu = document.getElementById('mobileMenu');
    menuBtn?.addEventListener('click', () => mobileMenu?.classList.toggle('hidden'));
</script>