---
interface Props {
    step: string;
    title: string;
    description: string;
    delay?: number;
}
const { step, title, description, delay = 0 } = Astro.props;
---
<div class="feature-card p-6 rounded-lg shadow-lg text-center" data-aos="fade-up" data-aos-delay={delay}>
    <div class="text-3xl font-bold text-indigo-400 mb-4">{step}</div>
    <h3 class="text-2xl font-semibold mb-2">{title}</h3>
    <p class="text-gray-300">{description}</p>
</div>