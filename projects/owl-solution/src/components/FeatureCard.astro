---
// src/components/FeatureCard.astro
interface Props {
    title: string;
    text: string;
    icon?: string;
    delay?: number;
    aosAnimation?: string; // добавим кастомную анимацию
}
const { title, text, icon, delay = 0, aosAnimation = "fade-up" } = Astro.props;
---
<div class="feature-card p-6 rounded-lg shadow-lg" data-aos={aosAnimation} data-aos-delay={delay}>
    {icon && <div class="mb-4 h-12 w-12 flex items-center justify-center"><img src={icon} alt={title} class="icon" /></div>}
    <h3 class="text-2xl font-semibold mb-2">{title}</h3>
    <p class="text-gray-300" set:html={text} />
</div>