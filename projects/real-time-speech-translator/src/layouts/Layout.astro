---
// src/layouts/Layout.astro

import '../styles/global.css';
import { ClientRouter } from "astro:transitions";

interface Props {
    title?: string;
    description?: string;
    image?: string;
}

const {
    title = "Real-Time AI Speech Translation | Millisecond Latency Engine",
    description = "Next-generation language bridging infrastructure for live events and broadcasts. High-precision, transformer-based AI translation with millisecond latency.",
    image = "/img/og-translator.png"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || "https://speech-translator.tsb-enterprise.com");

---
<html lang="en">
<head>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content="index, follow" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />
    <meta property="og:site_name" content="TSB // Core" />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url)} />

    <meta name="keywords" content="AI, real-time translation, speech-to-text, low latency, websocket audio, transformer models, TSB, Targeted Solutions for Business " />
    <meta name="theme-color" content="#0f172a" /> <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" type="image/svg+xml" href="/img/favicon.png" />

    <link rel="sitemap" href="/sitemap-index.xml" />

    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "TSB Speech Translator",
        "operatingSystem": "Web",
        "applicationCategory": "BusinessApplication, MultimediaApplication",
        "offers": {
            "@type": "Offer",
            "price": "0.00",
            "priceCurrency": "USD"
        },
        "description": description,
        "provider": {
            "@type": "Organization",
            "name": "Targeted Solutions for Business",
            "url": "https://tsb-enterprise.com"
        },
        "featureList": [
            "Real-time stream processing",
            "Transformer-based language models",
            "WebSocket-driven audio pipeline",
            "Zero-install web architecture"
        ]
    })} />

    <ClientRouter />
</head>
<body class="overflow-x-hidden bg-slate-900 text-slate-400">
<div class="fixed inset-0 hero-gradient pointer-events-none"></div>
<slot />
</body>
</html>