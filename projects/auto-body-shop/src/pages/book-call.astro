---
import MainLayout from '../layouts/MainLayout.astro';
import BookingVideoCall from '../components/BookingVideoCall.vue';

import { Image } from 'astro:assets';
import carHoodImg from '../assets/img/car-open-hood.jpg';
---

<MainLayout title="Video Call | Auto Body Atelier">
    <main class="relative min-h-screen flex items-center overflow-hidden bg-[#050505]">

        <!-- Background -->
        <div class="absolute inset-0 z-0">
            <Image
                    src={carHoodImg}
                    alt="Car engine bay"
                    width={1920}
                    height={1080}
                    widths={[240, 540, 720, 1020, 1600, carHoodImg.width]}
                    sizes={`100vw`}
                    format="webp"
                    quality="mid"
                    class="w-full h-full object-cover opacity-40 grayscale"
                    loading="eager"
                    fetchpriority="high"
            />
            <div class="absolute inset-0 bg-gradient-to-r from-[#050505] via-black/80 to-transparent"></div>
            <div class="absolute inset-0 bg-gradient-to-t from-[#050505] via-transparent to-black/60"></div>
        </div>

        <section class="relative z-10 w-full max-w-[1440px] mx-auto px-6 py-32">
            <div class="grid lg:grid-cols-2 gap-24 items-center">

                <!-- LEFT CONTENT -->
                <div class="space-y-10 text-center lg:text-left">
                    <div>
            <span class="text-primary uppercase tracking-[0.4em] text-xs font-bold">
              Collision Repair Experts
            </span>
                        <h1 class="mt-6 font-heading text-5xl md:text-6xl xl:text-7xl tracking-wider text-white leading-tight">
                            Your Online Car Inspection –  <br/>
                            <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-orange-300">
                Book a Video Call
              </span>
                        </h1>
                    </div>

                    <p class="text-gray-300 text-lg md:text-xl leading-relaxed max-w-xl mx-auto lg:mx-0">
                        Let us guide you through your repair options. Select your preferred time slots and platform.
                    </p>

                    <div class="pt-10 border-t border-white/10">
                        <p class="text-xs uppercase tracking-[0.3em] text-gray-500">
                            Trusted by vehicle owners across Washington
                        </p>
                    </div>
                </div>

                <!-- RIGHT FORM -->
                <div class="relative group flex justify-center lg:justify-end">
                    <div class="absolute -inset-1 bg-gradient-to-r from-primary to-orange-400 rounded-2xl blur opacity-20 group-hover:opacity-40 transition duration-700"></div>
                    <div class="relative w-full max-w-md">
                        <BookingVideoCall client:load />
                    </div>
                </div>

            </div>
        </section>
    </main>
</MainLayout>