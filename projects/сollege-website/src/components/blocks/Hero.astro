---
// components/blocks/Hero.astro
const { title, subtitle } = Astro.props;
---

<section class="relative bg-slate-900 text-white overflow-hidden py-24">
    <div class="absolute inset-0 opacity-20 pointer-events-none select-none" aria-hidden="true">
        <div class="absolute inset-0" style="background-image: radial-gradient(#334155 1px, transparent 1px); background-size: 40px 40px;"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-slate-900/50 via-transparent to-slate-900"></div>
    </div>

    <div class="relative max-w-6xl mx-auto px-4 z-10 text-center md:text-left">
        <div class="flex flex-col md:flex-row items-center gap-12">

            <div class="flex-1">
                <h1 class="text-5xl font-extrabold mb-6 tracking-tight italic uppercase">
                    <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-emerald-400">
                        {title}
                    </span>
                </h1>
                <p class="text-xl text-slate-300 max-w-2xl leading-relaxed">
                    {subtitle}
                </p>

                <div class="mt-10 flex flex-wrap gap-4 justify-center md:justify-start">
                    <a href="/schedule" class="bg-blue-600 hover:bg-blue-500 text-white px-8 py-3 rounded-xl font-semibold transition-all shadow-lg shadow-blue-900/20 active:scale-95">
                        Розклад
                    </a>
                    <a href="/admission" class="border border-slate-700 bg-slate-800/50 backdrop-blur-sm hover:border-blue-400 px-8 py-3 rounded-xl font-semibold transition-all">
                        Вступ
                    </a>
                </div>
            </div>

            <div class="flex-1 flex justify-center">
                <div class="relative w-80 h-80 flex items-center justify-center">

                    <div class="absolute w-full h-full border-2 border-blue-500/20 rounded-full animate-[ping_4s_linear_infinite]"></div>
                    <div class="absolute w-[85%] h-[85%] border border-emerald-500/20 rounded-full animate-[ping_5s_linear_infinite] animation-delay-500"></div>

                    <div class="absolute w-56 h-56 bg-blue-500/30 blur-[60px] rounded-full"></div>

                    <div class="relative z-20 p-2 bg-gradient-to-br from-blue-400 to-blue-600 rounded-full shadow-[0_0_50px_rgba(59,130,246,0.5)] group">
                        <div class="w-48 h-48 rounded-full overflow-hidden border-4 border-slate-900">
                            <img
                                    src="/img/logo.jpg"
                                    alt="Логотип ліцею"
                                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                            />
                        </div>

                        <div class="absolute inset-0 rounded-full bg-gradient-to-tr from-transparent via-white/10 to-transparent pointer-events-none"></div>
                    </div>

                    {[...Array(6)].map((_, i) => (
                            <div
                                    class="absolute w-2 h-2 bg-emerald-400 rounded-full opacity-60 shadow-[0_0_10px_#34d399]"
                                    style={`
                    transform: rotate(${i * 60}deg) translateY(-140px);
                    animation: orbit 10s linear infinite;
                    animation-delay: ${i * 0.5}s;
                `}
                            ></div>
                    ))}
                </div>
            </div>

        </div>
    </div>
</section>
<style>

    @keyframes orbit {
        from { transform: rotate(0deg) translateY(-140px) rotate(0deg); }
        to { transform: rotate(360deg) translateY(-140px) rotate(-360deg); }
    }

</style>