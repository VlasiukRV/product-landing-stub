---
const { title, staff = [], showFilters = false } = Astro.props;

const categories = [
    { key: "all", label: "Всі" },
    { key: "admin", label: "Адміністрація" },
    { key: "teachers", label: "Викладачі" },
    { key: "masters", label: "Майстри" },
    { key: "specialists", label: "Педагогічні працівники" }
];
---

<section class="w-full py-4">
    {title && (
            <div class="flex items-center gap-4 mb-8">
                <h2 class="text-2xl font-bold text-slate-800">{title}</h2>
                <div class="flex-1 h-[1px] bg-slate-100"></div>
            </div>
    )}

    {showFilters && (
            <div class="flex flex-wrap gap-2 mb-10 p-1 bg-slate-100/50 rounded-2xl w-fit">
                {categories.map((c) => (
                        <button
                                class="px-5 py-2 text-sm font-bold rounded-xl transition-all duration-200 border border-transparent data-[active=true]:bg-white data-[active=true]:text-blue-600 data-[active=true]:shadow-sm text-slate-500 hover:text-slate-800"
                                data-filter={c.key}
                                data-active={c.key === "all" ? "true" : "false"}
                        >
                            {c.label}
                        </button>
                ))}
            </div>
    )}

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="staffGrid">
        {staff.map((person) => (
                <a
                        href={`/staff/${person.id}`}
                        class="group relative block bg-white border border-slate-100 rounded-2xl p-6 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
                        data-category={person.category}
                >
                    <div class="flex items-start gap-4">
                        <div class="relative">
                            <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-slate-100 to-slate-200 flex items-center justify-center text-xl font-bold text-slate-500 border border-white shadow-inner group-hover:from-blue-50 group-hover:to-blue-100 group-hover:text-blue-600 transition-colors">
                                {person.image ? (
                                        <img src={person.image} alt={person.name} class="w-full h-full object-cover rounded-2xl" />
                                ) : (
                                    person.name?.charAt(0)
                                )}
                            </div>
                            <div class="absolute -bottom-1 -right-1 w-4 h-4 bg-emerald-500 border-2 border-white rounded-full"></div>
                        </div>

                        <div class="flex-1">
                            <h3 class="font-bold text-slate-900 leading-tight group-hover:text-blue-600 transition-colors">
                                {person.name}
                            </h3>
                            <p class="text-xs font-semibold uppercase tracking-wider text-blue-500 mt-1">
                                {person.position}
                            </p>
                        </div>
                    </div>

                    <div class="my-4 h-[1px] bg-slate-50"></div>

                    <div class="space-y-2">
                        {person.department && (
                                <div class="flex items-center gap-2 text-sm text-slate-500">
                                    <span class="text-slate-300">🏢</span>
                                    <span class="font-medium text-slate-600">{person.department}</span>
                                </div>
                        )}
                        <div class="text-xs text-slate-400 italic">
                            Натисніть для перегляду профілю
                        </div>
                    </div>

                    <div class="absolute top-6 right-6 opacity-0 group-hover:opacity-100 transition-opacity">
                        <svg class="w-4 h-4 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                    </div>
                </a>
        ))}
    </div>

    {showFilters && (
        <script is:inline>
            const buttons = document.querySelectorAll("[data-filter]");
            const cards = document.querySelectorAll("[data-category]");

            buttons.forEach((btn) => {
                btn.addEventListener("click", () => {
                    const filter = btn.dataset.filter;

                    buttons.forEach(b => b.setAttribute("data-active", "false"));
                    btn.setAttribute("data-active", "true");

                    cards.forEach((card) => {
                        const cat = card.dataset.category;
                        if (filter === "all" || filter === cat) {
                            card.style.display = "block";
                            card.style.opacity = "0";
                            setTimeout(() => card.style.opacity = "1", 10);
                        } else {
                            card.style.display = "none";
                        }
                    });
                });
            });
            </script>
    )}
</section>