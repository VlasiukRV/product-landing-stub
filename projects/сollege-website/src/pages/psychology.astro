---
import PageLayout from "../layouts/PageLayout.astro";
import FileList from "../components/ui/FileList.astro";

const consultationTypes = [
    { title: "Індивідуальні бесіди", icon: "👤", desc: "Конфіденційні зустрічі для вирішення особистих питань." },
    { title: "Групові тренінги", icon: "👥", desc: "Робота в команді, розвиток емпатії та навичок спілкування." },
    { title: "Профорієнтація", icon: "🧭", desc: "Допомога у визначенні кар'єрного шляху та сильних сторін." }
];

const selfHelpResources = [
    { name: "Техніки самозаспокоєння при стресі", url: "/docs/stress-relief.pdf", size: "1.2 MB" },
    { name: "Як підготуватися до іспитів без паніки", url: "/docs/exam-prep.pdf", size: "800 KB" },
    { name: "Гайд: Ефективне планування часу", url: "/docs/time-management.docx", size: "1.1 MB" }
];
---

<PageLayout
        title="Психологічна служба"
        breadcrumbs={[{ label: "Психолог" }]}
>
    <section class="max-w-7xl mx-auto px-6 py-12">
        <div class="relative bg-emerald-50 rounded-[3rem] p-8 md:p-16 overflow-hidden border border-emerald-100">
            <div class="absolute top-0 right-0 w-64 h-64 bg-emerald-200/40 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>

            <div class="relative z-10 max-w-3xl">
                <span class="inline-block px-4 py-1.5 bg-emerald-600/10 text-emerald-700 rounded-full text-[10px] font-black uppercase tracking-widest mb-6">
                    Твій ментальний простір
                </span>
                <h1 class="text-4xl md:text-5xl font-black text-slate-900 mb-6 leading-tight">
                    Ти не один. <br/><span class="text-emerald-600">Ми завжди вислухаємо.</span>
                </h1>
                <p class="text-slate-600 text-lg leading-relaxed mb-8">
                    Психологічна служба технікуму — це безпечне місце, де ти можеш поділитися своїми переживаннями, отримати підтримку та знайти відповіді на важливі запитання.
                </p>
                <div class="flex flex-col sm:flex-row gap-4">
                    <a href="#appointment" class="px-8 py-4 bg-emerald-400 text-white rounded-2xl font-bold text-lg text-center hover:bg-emerald-700 hover:scale-105 hover:shadow-xl hover:shadow-emerald-600/20 transition-all duration-300">
                        Записатися на консультацію
                    </a>
                    <a href="https://t.me/your_college_psychologist" class="px-8 py-4 bg-white text-emerald-700 border border-emerald-200 rounded-2xl font-bold text-center hover:bg-emerald-50 transition-all">
                        Написати в Telegram
                    </a>
                </div>
            </div>
        </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {consultationTypes.map(item => (
                    <div class="p-8 bg-white border border-slate-100 rounded-[2.5rem] shadow-sm hover:shadow-md transition-all">
                        <div class="text-4xl mb-6">{item.icon}</div>
                        <h3 class="text-xl font-bold text-slate-900 mb-3">{item.title}</h3>
                        <p class="text-slate-500 text-sm leading-relaxed">{item.desc}</p>
                    </div>
            ))}
        </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 py-12">
        <div class="flex flex-col md:flex-row gap-12 items-center bg-white border border-slate-100 rounded-[3rem] p-8 md:p-12 shadow-sm">
            <div class="w-48 h-48 md:w-64 md:h-64 flex-shrink-0 relative">
                <div class="absolute inset-0 bg-emerald-100 rounded-[3rem] rotate-3"></div>
                <img
                        src="http://bpl.kr.ua/images/news/2023/1_veresnja/ONOVLENI_FOTO/Ped.pracivnuku/1.jpg"
                        alt="Практичний психолог"
                        class="relative z-10 w-full h-full object-cover rounded-[3rem] -rotate-3 hover:rotate-0 transition-transform duration-500"
                />
            </div>
            <div class="flex-1">
                <h2 class="text-3xl font-black text-slate-900 mb-2">Веровенко Юлія Вікторівна</h2>
                <p class="text-emerald-600 font-bold mb-6 italic">Практичний психолог/ Соціальний педагог</p>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 text-sm">
                    <div class="space-y-3">
                        <p class="flex items-center gap-3 text-slate-600">
                            <span class="w-8 h-8 rounded-lg bg-slate-50 flex items-center justify-center">📅</span>
                            Пн — Пт: 09:00 - 16:00
                        </p>
                        <p class="flex items-center gap-3 text-slate-600">
                            <span class="w-8 h-8 rounded-lg bg-slate-50 flex items-center justify-center">📍</span>
                            Кабінет №204 (2 поверх)
                        </p>
                    </div>
                    <div class="space-y-3">
                        <p class="flex items-center gap-3 text-slate-600">
                            <span class="w-8 h-8 rounded-lg bg-slate-50 flex items-center justify-center">📧</span>
                            psycho-support@tech.edu.ua
                        </p>
                        <p class="flex items-center gap-3 text-slate-600">
                            <span class="w-8 h-8 rounded-lg bg-slate-50 flex items-center justify-center">📞</span>
                            +38 (067) 123-45-67
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="max-w-4xl mx-auto px-6 py-12">
        <div class="bg-slate-50 border border-slate-100 rounded-[3rem] p-8 md:p-12">
            <FileList title="Матеріали для самодопомоги" files={selfHelpResources} />
        </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 py-12 text-center">
        <div class="max-w-2xl mx-auto p-8 bg-amber-50 rounded-[2rem] border border-amber-100">
            <h4 class="text-amber-800 font-black mb-2 flex items-center justify-center gap-2">
                🔒 100% Конфіденційність
            </h4>
            <p class="text-amber-700/80 text-sm">
                Згідно з етичним кодексом психолога, все, що обговорюється на сесії, залишається між вами. Ми не передаємо інформацію адміністрації чи батькам без вашої згоди.
            </p>
        </div>
    </section>
</PageLayout>