---
import PageLayout from "../layouts/PageLayout.astro";
import professions from "../data/professions/index.json";

const documents = [
    "Заява на вступ (можна онлайн)",
    "Оригінал документа про освіту",
    "Копія свідоцтва про народження / ID-картки",
    "Медична довідка (форма №086У)",
    "Картка щеплень (форма №63)",
    "Довідка про склад сім'ї",
    "4 фотокартки (3x4)",
    "Ідентифікаційний код"
];
---

<PageLayout title="Набір 2026-2027">

    <section class="max-w-7xl mx-auto px-6 py-12">
        <div class="bg-primary-900 rounded-5xl p-8 md:p-16 relative overflow-hidden text-white shadow-card">
            <div class="relative z-10">
                <span class="inline-block px-4 py-1 bg-primary-600 rounded-xl text-[10px] font-black uppercase tracking-widest mb-6">
                    Вступна кампанія 2026
                </span>
                <h1 class="text-4xl md:text-6xl font-black mb-6 italic uppercase leading-tight">
                    Благовіщенський <br/><span class="text-primary-300">професійний ліцей</span>
                </h1>
                <p class="text-primary-100 text-lg mb-10 max-w-2xl">
                    Отримуй диплом кваліфікованого робітника, атестат про середню освіту та реальні професійні навички.
                </p>
                <a href="https://forms.gle/GT624thwHSsXDGrV6" target="_blank" class="inline-flex items-center gap-3 px-8 py-4 bg-white text-primary-900 rounded-2xl font-black uppercase tracking-widest text-sm hover:scale-105 transition-all">
                    Подати онлайн-заяву
                    <span class="text-xl">📄</span>
                </a>
            </div>
        </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-3 gap-6 mb-20">
        <div class="p-6 bg-emerald-50 border border-emerald-100 rounded-3xl flex items-center gap-4">
            <span class="text-3xl">💰</span>
            <div>
                <p class="text-[10px] font-black text-emerald-600 uppercase tracking-wider">Стипендія</p>
                <p class="font-bold text-slate-900">1250 грн/міс</p>
            </div>
        </div>
        <div class="p-6 bg-blue-50 border border-blue-100 rounded-3xl flex items-center gap-4">
            <span class="text-3xl">🏠</span>
            <div>
                <p class="text-[10px] font-black text-blue-600 uppercase tracking-wider">Проживання</p>
                <p class="font-bold text-slate-900">Безкоштовний гуртожиток</p>
            </div>
        </div>
        <div class="p-6 bg-orange-50 border border-orange-100 rounded-3xl flex items-center gap-4">
            <span class="text-3xl">🍲</span>
            <div>
                <p class="text-[10px] font-black text-orange-600 uppercase tracking-wider">Харчування</p>
                <p class="font-bold text-slate-900">Гарячі обіди для учнів</p>
            </div>
        </div>
    </section>

    <section class="max-w-7xl mx-auto px-6 py-12">
        <div class="mb-12">
            <h2 class="text-3xl font-black text-slate-900 uppercase italic">На базі 9 класів</h2>
            <p class="text-slate-500">З отриманням повної загальної середньої освіти</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
            {professions.map(item => (
                    <div class="bg-white border border-slate-100 p-8 rounded-4xl hover:shadow-card transition-all">
                        <a href={`/professions/${item.slug}`} >
                        <div class="text-4xl mb-6">{item.icon}</div>
                        <h3 class="text-xl font-bold text-slate-900 mb-2 leading-tight">{item.title}</h3>
                        <p class="text-primary-600 text-xs font-black uppercase mb-4 tracking-widest">{item.duration} навчання</p>
                        <p class="text-slate-500 text-sm leading-relaxed">{item.shortDescription}</p>
                        </a>
                    </div>
            ))}
        </div>

    </section>

    <section class="bg-surface-muted py-24 mt-12">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                <div>
                    <h2 class="text-3xl font-black text-slate-900 uppercase italic mb-8">Необхідні документи</h2>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        {documents.map(doc => (
                                <div class="flex items-center gap-3 p-4 bg-white rounded-2xl shadow-soft">
                                    <span class="text-emerald-500">✔</span>
                                    <span class="text-sm font-medium text-slate-700">{doc}</span>
                                </div>
                        ))}
                    </div>
                </div>
                <div class="bg-primary-600 rounded-5xl p-10 text-white relative overflow-hidden">
                    <div class="relative z-10">
                        <h3 class="text-2xl font-bold mb-4">Маєш запитання?</h3>
                        <p class="text-primary-100 mb-8">Ми допоможемо з подачею заяви та вибором професії.</p>
                        <div class="space-y-4">
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 bg-primary-700 rounded-full flex items-center justify-center">📍</div>
                                <span>вул. Студентська, 15</span>
                            </div>
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 bg-primary-700 rounded-full flex items-center justify-center">📞</div>
                                <span class="font-bold">+38 (0XX) XXX-XX-XX</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

</PageLayout>