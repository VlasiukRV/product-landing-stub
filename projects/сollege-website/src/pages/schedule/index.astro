---
// pages/schedule/index.astro
import PageLayout from "../../layouts/PageLayout.astro";
import GroupSelector from "../../components/schedule/GroupSelector.vue";
import groups from "../../data/groups.json";
---

<PageLayout
        title="Розклад занять"
        breadcrumbs={[{ label: "Розклад" }]}
>
    <section class="max-w-5xl mx-auto px-6 py-12 md:py-20">
        <div class="relative mb-16 text-center">
            <div class="absolute inset-x-0 -top-10 -z-10 flex justify-center opacity-20 blur-3xl">
                <div class="h-[150px] w-[300px] bg-blue-600 rounded-full"></div>
            </div>

            <h1 class="text-4xl md:text-5xl font-black text-slate-900 tracking-tight mb-4">
                Оберіть свою <span class="text-blue-600">групу</span>
            </h1>
            <p class="text-lg text-slate-500 max-w-xl mx-auto">
                Оберіть курс та спеціальність, щоб переглянути актуальний графік занять на поточний тиждень.
            </p>
        </div>

        <div class="bg-white border border-slate-100 rounded-[32px] p-2 shadow-2xl shadow-slate-200/60">
            <div class="bg-slate-50/50 rounded-[26px] p-8 md:p-12 border border-white/50">
                <GroupSelector client:load groups={groups} />
            </div>
        </div>

        <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-8 px-4">
            <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-full bg-blue-50 flex items-center justify-center text-blue-600 font-bold text-sm">A</div>
                <p class="text-sm text-slate-500 font-medium">Чисельник (тиждень A)</p>
            </div>
            <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-full bg-indigo-50 flex items-center justify-center text-indigo-600 font-bold text-sm">B</div>
                <p class="text-sm text-slate-500 font-medium">Знаменник (тиждень B)</p>
            </div>
            <div class="flex items-center gap-4">
                <div class="w-10 h-10 rounded-full bg-emerald-50 flex items-center justify-center text-emerald-600 font-bold text-sm">✓</div>
                <p class="text-sm text-slate-500 font-medium">Оновлено сьогодні</p>
            </div>
        </div>
    </section>
</PageLayout>