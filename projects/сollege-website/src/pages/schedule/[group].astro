---
// pages/schedule/[group].astro
import PageLayout from "../../layouts/PageLayout.astro";
import ScheduleTabs from "../../components/blocks/ScheduleTabs.astro";
import groups from "../../data/groups.json";

export async function getStaticPaths() {
    return groups.map((g) => ({
        params: { group: g.id }
    }));
}

const { group } = Astro.params;

// Знаходимо метадані групи для відображення красивого заголовка
const groupInfo = groups.find(g => g.id === group);

const scheduleModule = await import(`../../data/schedule/${group}.json`);
const data = scheduleModule.default;

const days = [
    { label: "Пн", key: "monday" }, // Скорочено для мобільних
    { label: "Вт", key: "tuesday" },
    { label: "Ср", key: "wednesday" },
    { label: "Чт", key: "thursday" },
    { label: "Пт", key: "friday" }
];
---

<PageLayout
        title={`Розклад: ${data.name || group}`}
        breadcrumbs={[
            { label: "Розклад", href: "/schedule" },
            { label: data.name || group }
        ]}
>
    <section class="max-w-5xl mx-auto px-6 py-10">

        <div class="bg-slate-900 rounded-[2rem] p-8 md:p-10 text-white mb-12 relative overflow-hidden shadow-xl">
            <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/4 w-64 h-64 bg-blue-500/20 rounded-full blur-3xl"></div>

            <div class="relative z-10 flex flex-col md:flex-row md:items-end justify-between gap-6">
                <div>
                    <div class="flex items-center gap-3 mb-4">
                        <span class="px-3 py-1 bg-blue-600 rounded-full text-[10px] font-black uppercase tracking-widest">
                            Група {data.name}
                        </span>
                        <span class="text-slate-400 text-sm font-medium">
                            {data.year} курс • {data.weekType === 'A' ? 'Тиждень А' : 'Тиждень B'}
                        </span>
                    </div>
                    <h1 class="text-3xl md:text-4xl font-black tracking-tight uppercase">
                        {data.specialty || "Спеціальність не вказана"}
                    </h1>
                </div>

                <div class="flex flex-col items-start md:items-end border-l md:border-l-0 md:border-t border-slate-700/50 pt-4 md:pt-0 pl-4 md:pl-0">
                    <span class="text-xs text-slate-500 uppercase font-bold tracking-widest mb-1">Статус розкладу</span>
                    <span class="text-emerald-400 font-bold flex items-center gap-2 text-sm">
                        <span class="w-2 h-2 bg-emerald-400 rounded-full animate-pulse"></span>
                        Актуальний на семестр
                    </span>
                </div>
            </div>
        </div>

        <div class="bg-white">
            <ScheduleTabs days={days} schedule={data.schedule} />
        </div>

        <div class="mt-12 p-6 rounded-2xl bg-blue-50 border border-blue-100 flex gap-4 items-start">
            <span class="text-2xl">💡</span>
            <div class="text-sm text-blue-800 leading-relaxed">
                <strong>Порада:</strong> Ви можете натиснути кнопку <strong>«Показати весь тиждень»</strong>, щоб зберегти розклад як PDF або швидко сфотографувати всі дні одразу.
            </div>
        </div>
    </section>
</PageLayout>