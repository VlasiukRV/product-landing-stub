---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Freshly Roasted Coffee" pageType="home">

    <main class="min-h-screen flex items-start md:items-center justify-center p-4 pt-10 md:pt-0">

        <section class="relative w-full max-w-6xl mx-auto flex flex-col md:flex-row items-center min-h-[600px] md:min-h-[500px] gap-8">

            <div class="w-full md:w-1/2 flex justify-end items-start md:items-center order-1 md:order-2">
                <img
                        src="/img/Wax-seal.png"
                        alt="Wax Seal"
                        class="w-40 md:w-52 lg:w-64 opacity-90 transition-transform duration-500 hover:scale-110 ease-in-out z-0
                               ml-0
                               -mt-12 md:-mt-[320px] xl:-mt-[420px]
                               md:-translate-y-10 lg:-translate-y-20"
                />
            </div>

            <div class="z-10 w-full md:w-1/2 flex flex-col justify-start md:justify-center items-start text-left order-2 md:order-1">
                <h1 class="text-4xl sm:text-5xl lg:text-7xl font-bold leading-tight mb-6 text-coffee-cream drop-shadow-[0_2px_10px_rgba(0,0,0,0.5)]">
                    FRESHLY<br>ROASTED<br>COFFEE BEANS
                </h1>

                <p class="text-base sm:text-lg lg:text-xl mb-6 text-coffee-light max-w-md">
                    Experience the aroma and flavor of our crafted coffee.
                </p>

                <div>
                    <a href="/cart"
                       class="btn inline-block bg-orange-700 hover:bg-orange-800 text-white text-base sm:text-lg px-8 py-4 rounded-lg shadow transition duration-200 uppercase tracking-wider">
                        SHOP NOW
                    </a>
                </div>
            </div>

        </section>
    </main>

</Layout>