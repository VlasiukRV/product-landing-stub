---
// src/components/ProductCard.astro
const { product } = Astro.props;
---

<div class="bg-stone-900 border border-white/5 rounded-2xl overflow-hidden hover:border-orange-700/50 transition-all duration-500 hover:shadow-2xl flex flex-col h-full group">
    <a href={`/shop/${product.id}`} class="block h-64 overflow-hidden shrink-0">
        <img
                src={product.image}
                alt={product.name}
                loading="lazy"
                class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-700"
        />
    </a>

    <div class="p-5 flex flex-col flex-grow">
        <h3 class="text-xl font-display text-coffee-cream mb-1">{product.name}</h3>
        <p class="text-sm text-stone-400 mb-4 line-clamp-2 flex-grow">{product.description}</p>

        <div class="flex items-center justify-between mt-auto">
            <span class="text-lg font-bold text-orange-400">${product.price.toFixed(2)}</span>

            <button
                    data-product={JSON.stringify(product)}
                    class="add-to-cart-btn bg-coffee-cream text-stone-900 px-4 py-2 rounded-lg font-bold text-sm uppercase tracking-wider hover:bg-orange-500 transition"
            >
                Add
            </button>
        </div>
    </div>
</div>

<script>

    document.querySelectorAll('.add-to-cart-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            const product = JSON.parse(e.target.dataset.product);

            let cart = JSON.parse(localStorage.getItem("cart") || "[]");
            const existing = cart.find(i => i.id === product.id);

            if (existing) {
                existing.quantity += 1;
            } else {
                cart.push({ ...product, quantity: 1 });
            }

            localStorage.setItem("cart", JSON.stringify(cart));
            alert(`${product.name} added to cart!`);
        });
    });
</script>