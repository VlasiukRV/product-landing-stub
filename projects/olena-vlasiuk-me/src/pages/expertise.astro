---
import MainLayout from '../layouts/MainLayout.astro';
import {expertiseData} from '../data/expertise';
---

<MainLayout title="Expertise — Olena Vlasiuk">
    <div class="max-w-4xl pb-20">

        {/* Основні секції */}
        {[
            {id: 'scientific', data: expertiseData.scientific},
            {id: 'patents', data: expertiseData.patents},
            {id: 'business', data: expertiseData.business},
            {id: 'mentorship', data: expertiseData.mentorship}
        ].map((sec) => (
                <section class="group">
                    {/* Збільшений внутрішній відступ секції */}
                    <div class="grid grid-cols-1 md:grid-cols-[250px_1fr] gap-8 py-16 first:pt-0">
                        <div class="relative">
                            <h3 class="text-xl font-bold text-[#c1eb70] tracking-tight">{sec.data.title}</h3>
                            <div class="h-[2px] w-12 bg-[#a4f1f6] mt-2 md:hidden"></div>
                        </div>

                        <div class="space-y-8">
                            {sec.data.note && (
                                    <p class="text-sm italic text-white/40 border-l-2 border-[#eeb5d3] pl-3">
                                        {sec.data.note}
                                    </p>
                            )}

                            {/* Наукові публікації */}
                            {sec.id === 'scientific' && (
                                    <div class="p-2 rounded-xl bg-white/5 border border-white/10 hover:border-[#a4f1f633] hover:bg-white/10 transition-all">
                                    <a href="https://scholar.google.com.ua/citations?user=QtFVwn8AAAAJ"
                                       target="_blank"
                                       class="inline-flex items-center text-[13px] text-[#a4f1f6] opacity-70 hover:opacity-100 transition-all group">
                                        <span class="border-b border-[#a4f1f6]/20 group-hover:border-[#a4f1f6] pb-0.5">
                                            List of publications
                                        </span>
                                        <svg xmlns="http://www.w3.org/2000/svg"
                                             class="w-3 h-3 ml-1.5 opacity-60 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform"
                                             fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                                        </svg>
                                    </a>
                                    </div>
                            )}

                            {/* Патенти */}
                            {sec.id === 'patents' && (
                                    <div class="grid grid-cols-1 gap-5">
                                        {sec.data.items.map(patent => (
                                                <div class="p-2 rounded-xl bg-white/5 border border-white/10 hover:border-[#a4f1f633] hover:bg-white/10 transition-all">
                                                <a href={patent.link} target="_blank">
                                                    <span class="text-[#eeb5d3] font-mono text-[10px] uppercase tracking-widest block mb-2">
                                                        Patent {patent.id}
                                                    </span>
                                                    <span class="text-white font-medium leading-snug">{patent.title}</span>
                                                </a>
                                                </div>
                                        ))}
                                    </div>
                            )}

                            {/* Бізнес-публікації */}
                            {sec.id === 'business' && (
                                    <div class="space-y-10"> {/* Глибокий відступ між статтями */}
                                        {sec.data.items.map(item => (
                                                <div class="p-2 rounded-xl bg-white/5 border border-white/10 hover:border-[#a4f1f633] hover:bg-white/10 transition-all">
                                                <div class="group/item">
                                                    <div class="p-2 rounded-xl bg-white/5 border border-white/10 hover:border-[#a4f1f633] hover:bg-white/10 transition-all">
                                                    <a href={item.link} target="_blank"
                                                       class="text-[#a4f1f6] group-hover/item:text-white font-bold block mb-2 transition-colors text-lg">
                                                        {item.title} {item.isNewsletter &&
                                                            <sup class="text-[#eeb5d3] ml-1 uppercase text-[10px]">blog</sup>}
                                                    </a>
                                                    {item.description &&
                                                            <p class="text-white/60 text-sm leading-relaxed max-w-2xl">{item.description}</p>}
                                                    </div>
                                                </div>
                                                </div>
                                        ))}
                                    </div>
                            )}

                            {/* Менторство */}
                            {sec.id === 'mentorship' && (
                                    <div class="space-y-10">
                                        {sec.data.items.map(item => (

                                                <div class="space-y-3 p-2 rounded-xl bg-white/5 border border-white/10 hover:border-[#a4f1f633] hover:bg-white/10 transition-all">
                                                    <div class="flex flex-wrap items-baseline gap-2">
                                                        <span class="text-[#eeb5d3] font-bold uppercase text-[11px] tracking-wider">{item.role}</span>
                                                        {item.link ? (
                                                                <a href={item.link} target="_blank"
                                                                   class="text-white font-semibold hover:text-[#a4f1f6] underline decoration-white/20 underline-offset-4">{item.event}</a>
                                                        ) : (
                                                                <span class="text-white font-semibold">{item.event}</span>
                                                        )}
                                                    </div>
                                                    <p class="text-white/60 text-sm leading-relaxed max-w-2xl">{item.description}</p>
                                                </div>
                                        ))}
                                    </div>
                            )}
                        </div>
                    </div>

                    {/* Розділювальна лінія з великим відступом знизу mb-20 */}
                    <div class="mt-4 mb-20 h-[1px] w-full bg-gradient-to-r from-[#a4f1f633] via-white/10 to-transparent relative last:hidden">
                        <div class="absolute -top-[3px] left-0 w-1.5 h-1.5 rounded-full bg-[#a4f1f6] shadow-[0_0_8px_#a4f1f6]"></div>
                    </div>
                </section>
        ))}

        {/* Секція конференцій */}
        <section class="pt-10">
            <div class="grid grid-cols-1 md:grid-cols-[250px_1fr] gap-8">
                <h3 class="text-xl font-bold text-[#c1eb70]">Conferences & Events</h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-12 gap-y-8">
                    {expertiseData.events.map(event => (
                            <div class="flex items-start gap-3 group text-sm leading-relaxed p-2 rounded-xl bg-white/5 border border-white/10 hover:border-[#a4f1f633] hover:bg-white/10 transition-all">
                                <span class="text-[#eeb5d3] font-bold mt-0.5">/</span>
                                <div>
                                    {event.link ? (
                                            <a href={event.link} target="_blank"
                                               class="text-white/70 group-hover:text-[#a4f1f6] transition-colors">
                                                {event.title}
                                            </a>
                                    ) : (
                                            <span class="text-white/50">{event.title}</span>
                                    )}
                                    {event.badge && (
                                            <span class="inline-block bg-[#eeb5d3]/10 text-[#eeb5d3] text-[9px] px-1.5 py-0.5 rounded border border-[#eeb5d3]/20 ml-2 uppercase font-bold tracking-tighter">
                                        {event.badge}
                                    </span>
                                    )}
                                </div>
                            </div>
                    ))}
                </div>
            </div>
        </section>
    </div>
</MainLayout>