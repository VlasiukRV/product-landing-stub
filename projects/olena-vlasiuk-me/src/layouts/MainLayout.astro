---
import { Image } from 'astro:assets';
import imageHero from '../assets/olena-vlasiuk.jpg';

import '../styles/global.css';
import { ClientRouter } from "astro:transitions";

interface Props {
    title?: string;
    description?: string;
    image?: string;
}

const {
    title = "Olena Vlasiuk, Ph. D. — About Me",
    description = "Olena Vlasiuk, Ph.D. – Expert in Digital Transformation, Business Strategy, and Academic Research. Shaping future digital ecosystems through innovative solutions.",
    image = "/images/webclip.png"
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { pathname } = Astro.url;
const currentPath = pathname.replace(/\/$/, "") || "/";

const isActive = (path: string) =>
    currentPath === path
        ? "text-[#c1eb70] border-b-2 border-[#c1eb70]"
        : "text-white/60 hover:text-white transition-colors";
---

<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="profile" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url)} />

    <link rel="icon" type="image/png" href="/favicon.png" />

    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Olena Vlasiuk",
        "honorificPrefix": "Dr.",
        "honorificSuffix": "Ph.D.",
        "jobTitle": "Expert in Digital Transformation",
        "knowsAbout": ["Digital Transformation", "Business Strategy", "Information Technology"],
        "alumniOf": { "@type": "CollegeOrUniversity", "name": "Cherkasy state technological university" },
        "url": "https://olena.vlasiuk.me",
        "image": "https://olena.vlasiuk.me/images/olena-vlasiuk.jpg",
        "sameAs": [
            "https://linkedin.com/in/olenavlasiuk/",
            "https://scholar.google.com.ua/citations?user=QtFVwn8AAAAJ",
            "https://olena.vlasiuk.me/",
            "https://tsb-enterprise.com/",
            "https://uptarget.co/"
      ],
        "description": description
    })} />

    <ClientRouter />
    <style is:global>
        @font-face {
            font-weight: 400; font-style: normal; font-display: swap;
        }
        body { font-family: 'Golos Text', sans-serif; }
    </style>
</head>

<body class="bg-[#3e5153] text-white antialiased">
<div class="flex flex-col lg:flex-row min-h-screen relative">

    <aside class="lg:sticky lg:top-0 lg:h-screen w-full lg:w-[700px] lg:min-w-[700px] lg:max-w-[700px] flex flex-col z-50"
           transition:persist>
        <div class="relative w-full h-[450px] md:h-[650px] lg:h-full lg:flex-1 overflow-hidden">
            <Image
                    src={imageHero}
                    alt="Olena Vlasiuk"
                    loading="eager"
                    class="absolute inset-0 w-full h-full object-cover object-[center_20%]"
                    transition:name="hero-image"
            />
        </div>

        <div class="bg-[#7d9c9fb3] backdrop-blur-[15px] p-8 md:p-12 flex flex-col items-center justify-center gap-5 text-center">
            <h1 class="text-3xl md:text-4xl font-medium text-white">Olena Vlasiuk, Ph. D.</h1>
            <div class="flex gap-3">
                <a href="tel:217-254-7159" class="w-11 h-11 flex items-center justify-center rounded-full bg-white/5 hover:bg-[#3e5153] transition-colors border border-white/20">
                    <img src="/images/phone.svg" class="w-5 h-5" alt="Phone" />
                </a>
                <a href="mailto:alyona.lisitsyna@gmail.com" class="w-11 h-11 flex items-center justify-center rounded-full bg-white/5 hover:bg-[#3e5153] transition-colors border border-white/20">
                    <img src="/images/email.svg" class="w-5 h-5" alt="Email" />
                </a>
                <a href="https://linkedin.com/in/olenavlasiuk/" target="_blank" class="w-11 h-11 flex items-center justify-center rounded-full bg-white/5 hover:bg-[#3e5153] transition-colors border border-white/20">
                    <img src="/images/linkedIn.svg" class="w-5 h-5" alt="LinkedIn" />
                </a>
            </div>
        </div>
    </aside>

    <main class="flex-1 flex flex-col relative">
        <nav class="sticky top-0 z-[100] bg-[#3e515380] backdrop-blur-[15px] w-full py-6 px-4">
            <div class="max-w-[590px] mx-auto flex justify-center gap-6 md:gap-10 text-sm md:text-base">
                <a href="/" class={isActive("/")}>About Me</a>
                <a href="/experience" class={isActive("/experience")}>Experience</a>
                <a href="/expertise" class={isActive("/expertise")}>Expertise</a>
                <a href="/education" class={isActive("/education")}>Education</a>
            </div>
        </nav>

        <div class="px-6 py-10 md:px-20 lg:py-24 max-w-5xl mx-auto">
            <slot />
        </div>
    </main>
</div>
</body>
</html>