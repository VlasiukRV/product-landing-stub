---
const navLinks = [
    { href: "#About", label: "About" },
    { href: "#Projects", label: "Projects" },
    { href: "#Connect", label: "Connect" },
];
---

<nav class="fixed bottom-0 left-0 z-50 flex flex-col items-start gap-0 pointer-events-none">

    <div class="menubar flex items-center bg-white/70 backdrop-blur-md pointer-events-auto shadow-2xl overflow-hidden">

        <a href="#Start" class="p-4 border-brand-purple/10 hover:bg-brand-purple/10 transition-colors">
            <img
                    src="/img/logo-menu.svg"
                    alt="Logo"
                    class="w-6 h-6"
            />
        </a>

        <div class="flex">
            {navLinks.map(link => (
                    <a
                            href={link.href}
                            class="px-6 py-4 text-[12px] font-bold uppercase tracking-[0.15em] text-brand-purple hover:text-white hover:bg-brand-purple transition-all border-r border-brand-purple/10 last:border-r-0"
                    >
                        {link.label}
                    </a>
            ))}
        </div>
    </div>
</nav>

<style>
    .menubar {
        transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
    }
    .menubar:hover {
        transform: translate3d(10px, 0, 0);
        background-color: rgba(255, 255, 255, 0.9);
    }
</style>