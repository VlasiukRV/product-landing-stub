---

import DynamicSynapseForm from '../components/DynamicSynapseForm.vue';

const currentYear = new Date().getFullYear();
---

<section id="Connect" class="py-24 bg-gray-50 overflow-hidden">
    <div class="max-w-7xl md:max-w-3xl lg:max-w-7xl mx-auto px-4">

        <div class="relative bg-white rounded-[2rem] p-10 md:p-20 shadow-sm border border-gray-100 overflow-hidden isolate">

            <div class="absolute top-0 left-0 w-2 h-full bg-brand-purple z-20"></div>
            <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] bg-brand-purple/5 rounded-full blur-[120px] z-0"></div>

            <div class="relative z-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-12">

                <div class="max-w-2xl">

                    <DynamicSynapseForm client:load />

                </div>

                <div class="flex flex-col gap-6 w-full md:w-[400px]">
                    <p class="text-xs font-bold uppercase tracking-[0.2em] text-gray-400 ml-2 mb-2">
                        Direct Channels
                    </p>

                    <a href="tel:+14845219686"
                       class="group relative flex items-center gap-6 p-2 pr-10 bg-white hover:bg-brand-purple transition-all duration-500 border border-gray-100 hover:border-brand-purple shadow-[0_4px_20px_-10px_rgba(0,0,0,0.05)] hover:shadow-[0_20px_40px_-15px_rgba(107,33,168,0.3)] overflow-hidden">

                        <div class="w-16 h-16 flex items-center justify-center bg-[rgb(244,244,244)] rounded-[1.8rem] group-hover:bg-white/10 transition-colors duration-500">
                            <img src="/img/call-ico.svg"
                                 alt="Call"
                                 class="w-6 h-6 group-hover:invert group-hover:brightness-0 transition-all duration-500"/>
                        </div>

                        <div class="flex flex-col">
                            <span class="text-[10px] font-bold uppercase tracking-widest text-gray-400 group-hover:text-white/60 transition-colors">Call us</span>
                            <span class="text-lg md:text-xl font-semibold text-gray-900 group-hover:text-white transition-colors tracking-tight">
                                +1 484 521 96 86
                            </span>
                        </div>

                        <div class="absolute right-6 opacity-0 group-hover:opacity-100 group-hover:translate-x-2 transition-all duration-500">
                            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                            </svg>
                        </div>
                    </a>

                    <a href="mailto:info@tsb-enterprise.com?subject=Mail%20from%20TSB%20Website"
                       class="group relative flex items-center gap-6 p-2 pr-10 bg-white hover:bg-brand-purple transition-all duration-500 border border-gray-100 hover:border-brand-purple shadow-[0_4px_20px_-10px_rgba(0,0,0,0.05)] hover:shadow-[0_20px_40px_-15px_rgba(107,33,168,0.3)] overflow-hidden">

                        <div class="w-16 h-16 flex items-center justify-center bg-[rgb(244,244,244)] rounded-[1.8rem] group-hover:bg-white/10 transition-colors duration-500">
                            <img src="/img/mail-ico.svg"
                                 alt="Mail"
                                 class="w-6 h-6 group-hover:invert group-hover:brightness-0 transition-all duration-500"/>
                        </div>

                        <div class="flex flex-col">
                            <span class="text-[10px] font-bold uppercase tracking-widest text-gray-400 group-hover:text-white/60 transition-colors">Email us</span>
                            <span class="text-lg md:text-xl font-semibold text-gray-900 group-hover:text-white transition-colors tracking-tight">
                                info@tsb-enterprise.com
                            </span>
                        </div>

                        <div class="absolute right-6 opacity-0 group-hover:opacity-100 group-hover:translate-x-2 transition-all duration-500">
                            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                            </svg>
                        </div>
                    </a>
                </div>

            </div>

            <div class="mt-20 pt-10 border-t border-gray-100 flex flex-col md:flex-row justify-between gap-6">
                <p class="text-gray-500 leading-relaxed">
                    30 N GOULD ST STE N SHERIDAN, WY 82801
                </p>
                <p class="text-gray-400">
                    © <span>{currentYear}</span> Targeted Solutions for Business. All rights reserved.
                </p>
            </div>

        </div>
    </div>
</section>