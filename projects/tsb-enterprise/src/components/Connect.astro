---
const currentYear = new Date().getFullYear();
---

<section id="Connect" class="py-24 bg-gray-50 overflow-hidden">
    <div class="max-w-7xl md:max-w-3xl lg:max-w-7xl mx-auto px-4">

        <div class="relative bg-white rounded-[2rem] p-10 md:p-20 shadow-sm border border-gray-100 overflow-hidden isolate">

            <div class="absolute top-0 left-0 w-2 h-full bg-brand-purple z-20"></div>
            <div class="absolute top-[-20%] right-[-10%] w-[500px] h-[500px] bg-brand-purple/5 rounded-full blur-[120px] z-0"></div>

            <div class="relative z-10 flex flex-col md:flex-row justify-between items-start md:items-center gap-12">

                <div class="max-w-2xl">
                    <h2 class="text-4xl md:text-5xl lg:text-6xl font-medium leading-[1.1] text-gray-900">
                        Want to collaborate, or learn more?<br/>
                        <span class="text-brand-purple">Let’s Connect</span>
                    </h2>
                </div>

                <div class="flex flex-col gap-6 w-full md:w-auto">

                    <a href="tel:+12172547159"
                       class="group flex items-center gap-6 p-4 pr-8 bg-gray-50 hover:bg-brand-purple transition-all duration-500 rounded-2xl border border-gray-100 hover:border-brand-purple shadow-sm">
                        <div class="w-16 h-16 flex items-center justify-center bg-white rounded-xl shadow-inner group-hover:scale-90 transition-transform duration-500">
                            <img src="/img/call-ico.svg"
                                 alt="Call" class="w-8 h-8"/>
                        </div>
                        <span class="text-xl font-medium text-gray-800 group-hover:text-white transition-colors">
                            +1 217 254 7159
                        </span>
                    </a>

                    <a href="mailto:info@tsb-enterprise.com?subject=Mail%20from%20TSB%20Website"
                       class="group flex items-center gap-6 p-4 pr-8 bg-gray-50 hover:bg-brand-purple transition-all duration-500 rounded-2xl border border-gray-100 hover:border-brand-purple shadow-sm">
                        <div class="w-16 h-16 flex items-center justify-center bg-white rounded-xl shadow-inner group-hover:scale-90 transition-transform duration-500">
                            <img src="/img/mail-ico.svg"
                                 alt="Mail" class="w-8 h-8"/>
                        </div>
                        <span class="text-xl font-medium text-gray-800 group-hover:text-white transition-colors">
                            info@tsb-enterprise.com
                        </span>
                    </a>

                </div>
            </div>

            <div class="mt-20 pt-10 border-t border-gray-100 flex flex-col md:flex-row justify-between gap-6">
                <p class="text-gray-500 leading-relaxed">
                    PO box 62, Arthur, IL, 61911, USA
                </p>
                <p class="text-gray-400">
                    © <span>{currentYear}</span> Targeted Solutions for Business. All rights reserved.
                </p>
            </div>

        </div>
    </div>
</section>