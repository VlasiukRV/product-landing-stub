---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
---

<Layout>

    <header class="mb-16 text-center">
        <h1>Vlasiuk</h1>
        <div class="text-text-dim text-lg mt-4 tracking-[0.1em]">FAMILY OFFICE & VENTURE STUDIO</div>
    </header>

    <section class="mb-20 text-center max-w-2xl mx-auto px-4">
        <h2 class="text-2xl font-bold mb-6 text-text-main">Building technology, businesses, and opportunities.</h2>
        <p class="text-text-dim leading-relaxed">
            The Vlasiuk family brings together entrepreneurship, technology leadership, education,
            and innovation to create products, companies, and initiatives that make a lasting impact.
        </p>
    </section>

    <section class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full mb-20">
        <Card
                href="https://olena.vlasiuk.me/"
                imgSrc="/img/olena_vlasiuk.webp"
                title="Meet Olena Vlasiuk"
                description="CEO, entrepreneur, advisor, and researcher with experience in technology, operations, and company growth."
                linkText="Visit Profile"
        />
        <Card
                href="#"
                imgSrc="/img/roman_vlasiuk.webp"
                title="Meet Roman Vlasiuk"
                description="Software engineer, and entrepreneur focused on cloud platforms, and digital products."
                linkText="Visit Profile"
        />
    </section>

    <!-- Ventures & Projects -->
    <section class="w-full">
        <h3 class="text-text-dim text-[0.75rem] uppercase tracking-[0.2em] font-semibold mb-10 text-center">Ventures & Projects</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <Card
                    href="https://tsb-enterprise.com/"
                    imgSrc="/img/tsb-Logo.svg"
                    title="TSB Enterprise"
                    description="Enterprise-grade digital solutions and consulting."
                    linkText="Launch Site"
            />
            <Card
                    href="https://uptarget.co/"
                    imgSrc="/img/uptarget_Logo.svg"
                    title="Uptarget"
                    description="Your Dedicated Team."
                    linkText="Launch Site"
            />
            <!-- Placeholder for open source / future -->
            <div class="card border border-card-border p-6 rounded-2xl flex flex-col justify-center items-center text-center opacity-60">
                <h4 class="text-white font-bold mb-2">Future Ventures</h4>
                <p class="text-text-dim text-sm">Building the next generation of digital ecosystems.</p>
            </div>
        </div>
    </section>

</Layout>