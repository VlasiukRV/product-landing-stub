---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
---

<Layout title="Vlasiuk Family & Ventures">
    <header class="mb-16 text-center">
        <h1>Vlasiuk</h1>
        <div class="text-text-dim text-lg mt-4 tracking-[0.1em]">FAMILY OFFICE & VENTURE STUDIO</div>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full">
        <Card
                href="https://olena.vlasiuk.me/"
                imgSrc="/img/olena_vlasiuk.webp"
                title="Dr Olena Vlasiuk"
                description="Expert insights into digital transformation and business strategy."
                linkText="View Portfolio"
        />
        <Card
                href="https://www.linkedin.com/in/romavlasuk"
                imgSrc="/img/roman_vlasiuk.webp"
                title="Roman Vlasiuk"
                description="Founder & Technology Strategist. Shaping future digital ecosystems."
                linkText="Get in Touch"
        />
        <Card
                href="https://tsb-enterprise.com/"
                imgSrc="/img/tsb-Logo.svg"
                title="Targeted Solutions"
                description="Enterprise-grade digital solutions and consulting."
                linkText="Launch Site"
        />
        <Card
                href="https://uptarget.co/"
                imgSrc="/img/uptarget_Logo.svg"
                title="UpTarget"
                description="Your Dedicated Team."
                linkText="Launch Site"
        />
    </div>

    <div class="mt-20 pt-10 border-t border-card-border text-center">
        <div class="text-text-dim text-[0.75rem] uppercase tracking-[0.2em] font-semibold mb-6">
            Proprietary Ecosystem
        </div>
        <div class="flex justify-center gap-8 flex-wrap">
            {['Owl Solution', 'Dynamic UI', 'Speech Translator'].map(item => (
                    <a href={`https://${item.toLowerCase().replace(' ', '-')}.tsb-enterprise.com/`}
                       class="text-text-dim no-underline text-sm transition-colors hover:text-accent">
                        {item}
                    </a>
            ))}
        </div>
    </div>
</Layout>