---
interface Props {
    href: string;
    imgSrc: string;
    title: string;
    description?: string;
    linkText: string;
}

const { href, imgSrc, title, description, linkText } = Astro.props;
---

<a href={href} class="card group">
    <img src={imgSrc} alt={title} class="card-image">
    <h2 class="text-2xl font-bold mb-2 text-text-main">{title}</h2>
    <p class="text-text-dim text-sm leading-relaxed min-h-[3em]">{description}</p>
    <div class="mt-5 text-sm font-semibold text-accent">{linkText} →</div>
</a>