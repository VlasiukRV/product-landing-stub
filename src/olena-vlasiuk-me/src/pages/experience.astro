---
import MainLayout from '../layouts/MainLayout.astro';
import { experiences } from '../data/experience';
---

<MainLayout title="Experience — Olena Vlasiuk">
    <section class="max-w-[800px]">
        <h2 class="text-2xl font-semibold mb-4">Professional Experience</h2>
        <div class="h-[1px] bg-[#a4f1f680] w-full mb-10"></div>

        <div class="space-y-12 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-transparent before:via-white/20 before:to-transparent">

            {experiences.map((item) => (
                    <div class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active">
                        <div class="flex items-center justify-center w-10 h-10 rounded-full border border-white/20 bg-[#3e5153] text-[#a4f1f6] shadow shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2">
                            <svg class="fill-current w-3 h-3" viewBox="0 0 12 12">
                                <path d="M10.434 8.474L6 4.04 1.566 8.474 0 6.908 6 0.908l6 6z" />
                            </svg>
                        </div>

                        <div class="w-[calc(100%-4rem)] md:w-[calc(50%-2.5rem)] p-6 rounded-[20px] bg-white/5 border border-white/10 hover:border-[#a4f1f680] transition-colors">
                            <div class="flex flex-col mb-1">
                                <time class="text-[#c1eb70] font-medium text-sm mb-1">{item.period}</time>
                                <h3 class="text-xl font-bold text-white leading-tight">
                                    {item.role}
                                </h3>
                                <div class="text-[#a4f1f6] font-medium italic">
                                    {item.link ? (
                                            <a href={item.link} target="_blank" class="hover:underline">{item.company}</a>
                                    ) : (
                                        item.company
                                    )}
                                    <span class="text-white/40 ml-2">— {item.location}</span>
                                </div>
                            </div>

                            <ul class="mt-4 space-y-2 text-white/70 text-sm leading-relaxed list-disc list-inside">
                                {item.description.map(point => (
                                        <li>{point}</li>
                                ))}
                            </ul>
                        </div>
                    </div>
            ))}
        </div>
    </section>
</MainLayout>