---
import { Image } from 'astro:assets';
import carBg from '../assets/img/car.jpg';
import { Image } from 'astro:assets';
import carHoodImg from '../assets/img/car-open-hood.jpg';
---

<section id="services" class="pt-40 py-24 bg-surface relative overflow-hidden">
    <div class="absolute inset-0 z-0">
        <Image
                src={carHoodImg}
                alt="Car engine bay"
                width={1920}
                height={1080}
                widths={[640, 1024, 1920]}
                sizes="(max-width: 1024px) 100vw, 1920px"
                format="webp"
                quality="mid"
                class="w-full h-full object-cover opacity-40 grayscale-[0.2]"
                loading="eager"
                fetchpriority="high"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-surface via-surface/40 to-surface"></div>
        <div class="absolute inset-0 bg-gradient-to-r from-surface via-transparent to-surface"></div>
    </div>

    <div class="absolute top-0 right-0 w-1/3 h-1/3 bg-primary/20 blur-[130px] rounded-full z-0"></div>

    <div class="max-w-6xl mx-auto px-6 relative z-10">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 gap-6">
            <div>
                <span class="text-primary uppercase tracking-widest text-sm font-bold">Mastery in Motion</span>
                <h2 class="text-5xl font-heading mt-2 text-white">Our Services</h2>
            </div>
            <p class="text-gray-400 max-w-md">
                We blend traditional craftsmanship with advanced technology to restore your vehicle to its showroom glory.
            </p>
        </div>

        <div class="grid md:grid-cols-3 gap-12">
            <div class="group relative bg-black/40 backdrop-blur-md p-10 rounded-2xl border border-white/10 hover:border-primary/50 transition-all duration-500 hover:-translate-y-2">
                <div class="text-6xl font-heading text-white/5 absolute top-6 right-8 group-hover:text-primary/10 transition-colors">01</div>

                <div class="mb-6 inline-block p-4 rounded-xl bg-primary/10 text-primary group-hover:bg-primary group-hover:text-black transition-all duration-300">
                    <svg viewBox="0 0 64 64" class="w-12 h-12" fill="none" stroke="currentColor" stroke-width="2" xmlns="http://www.w3.org/2000/svg">
                        <path d="M10 40 L10 32 C10 25 18 22 25 22 L40 22 C48 22 54 25 54 32 L54 40"
                              stroke-linecap="round" stroke-linejoin="round"/>
                        <line x1="8" y1="44" x2="56" y2="44" stroke-linecap="round"/>

                        <path d="M30 28 L34 36 M34 28 L30 36"
                              class="stroke-white group-hover:stroke-black transition-colors duration-300"
                              stroke-width="2.5"
                              stroke-linecap="round"/>

                        <circle cx="18" cy="44" r="4" fill="currentColor"/>
                        <circle cx="46" cy="44" r="4" fill="currentColor"/>
                    </svg>
                </div>
                <h3 class="font-heading text-2xl mb-4 text-white">Collision Repair</h3>
                <p class="text-gray-400 leading-relaxed">
                    Laser-precise structural restoration for luxury frames. We ensure your safety architecture is flawless.
                </p>
            </div>

            <div class="group relative bg-black/40 backdrop-blur-md p-10 rounded-2xl border border-white/10 hover:border-primary/50 transition-all duration-500 hover:-translate-y-2">
                <div class="text-6xl font-heading text-white/5 absolute top-6 right-8 group-hover:text-primary/10 transition-colors">02</div>
                <div class="mb-6 inline-block p-4 rounded-xl bg-primary/10 text-primary group-hover:bg-primary group-hover:text-black transition-all duration-300">
                    <svg viewBox="0 0 64 64" class="w-12 h-12" fill="none" stroke="currentColor" stroke-width="2" xmlns="http://www.w3.org/2000/svg">
                        <path d="M8 32 C20 32 24 22 32 22 C40 22 44 32 56 32" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M48 48 L32 32" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M52 52 L44 44" stroke-linecap="round" stroke-width="4"/>

                        <g class="stroke-white group-hover:stroke-black transition-colors duration-300">
                            <path d="M16 16 L16 10 M13 13 L19 13" stroke-linecap="round" stroke-width="1.5"/>
                            <path d="M42 14 L42 10 M40 12 L44 12" stroke-linecap="round" stroke-width="1.5"/>
                        </g>
                    </svg>
                </div>
                <h3 class="font-heading text-2xl mb-4 text-white">Dent & Scratch</h3>
                <p class="text-gray-400 leading-relaxed">
                    Paintless dent removal that preserves your original finish. Invisible repairs, zero compromise.
                </p>
            </div>

            <div class="group relative bg-black/40 backdrop-blur-md p-10 rounded-2xl border border-white/10 hover:border-primary/50 transition-all duration-500 hover:-translate-y-2">
                <div class="text-6xl font-heading text-white/5 absolute top-6 right-8 group-hover:text-primary/10 transition-colors">03</div>
                <div class="mb-6 inline-block p-4 rounded-xl bg-primary/10 text-primary group-hover:bg-primary group-hover:text-black transition-all duration-300">
                    <svg viewBox="0 0 64 64" class="w-12 h-12" fill="none" stroke="currentColor" stroke-width="2" xmlns="http://www.w3.org/2000/svg">
                        <path d="M20 40 L28 40 L32 24 L20 20 Z" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M28 40 L28 52" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M30 20 L40 12 L45 15 L35 23" stroke-linecap="round" stroke-linejoin="round"/>
                        <path d="M24 40 Q22 45 20 40" stroke-linecap="round"/>

                        <path d="M16 26 L4 20 M16 30 L6 30 M16 34 L4 40"
                              class="stroke-white group-hover:stroke-black transition-colors duration-300"
                              stroke-dasharray="2 4" stroke-linecap="round"/>
                    </svg>
                </div>
                <h3 class="font-heading text-2xl mb-4 text-white">Auto Painting</h3>
                <p class="text-gray-400 leading-relaxed">
                    Computerized color matching and premium clear coats. A deep, mirror-like gloss that lasts for years.
                </p>
            </div>

        </div>
    </div>
</section>