<section id="booking" class="py-24 bg-surface">
    <div class="max-w-3xl mx-auto px-6">
        <h2 class="text-4xl font-heading mb-8">Schedule Appointment</h2>

        <form id="bookingForm" class="space-y-6">
            <input type="text" name="name" placeholder="Full Name" class="w-full p-4 bg-surface rounded focus:ring-2 focus:ring-primary transition"/>
            <input type="tel" name="phone" placeholder="Phone Number" class="w-full p-4 bg-surface rounded focus:ring-2 focus:ring-primary transition"/>
            <textarea name="message" placeholder="Vehicle details" class="w-full p-4 bg-surface rounded focus:ring-2 focus:ring-primary transition"></textarea>
            <button type="submit" class="w-full py-4 border border-white/30 uppercase tracking-widest hover:bg-white hover:text-black transition">
                Request Estimate
            </button>
        </form>

    </div>
</section>

<script>
    const form = document.getElementById('bookingForm')
    const status = document.getElementById('formStatus')

    form.addEventListener('submit', async (e) => {
        e.preventDefault()

        const formData = new FormData(form)
        const data = Object.fromEntries(formData)

        const res = await fetch('https://your-fastapi-domain.com/api/booking', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })

        if (res.ok) {
            status.classList.remove('hidden')
            form.reset()
        }
    })
</script>