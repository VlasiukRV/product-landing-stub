{
  "name": "astro-monorepo-platform",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "build:all": "for d in projects/*/; do (cd \"$d\" && npx astro build); done",
    "dev": "cd projects/$SITE_NAME && npx astro dev --host 0.0.0.0",
    "build": "cd projects/$SITE_NAME && npx astro build"
  },
  "dependencies": {
    "@astrojs/node": "^9.0.0",
    "@astrojs/sitemap": "^3.2.0",
    "@astrojs/tailwind": "^5.1.4",
    "@astrojs/vue": "^5.1.3",
    "@nanostores/vue": "^0.11.0",
    "@tailwindcss/typography": "^0.5.15",
    "astro": "^5.4.0",
    "jwt-decode": "^4.0.0",
    "swiper": "^11.1.0",
    "tailwindcss": "^3.4.1",
    "vue": "^3.5.0"
  }
}
